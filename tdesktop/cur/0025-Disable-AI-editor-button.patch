Subject: [PATCH 25/27] Disable AI editor button

Fun fact: both of these functions are identical. Why?
---
 Telegram/SourceFiles/history/history_widget.cpp                  | 1 +
 .../history/view/controls/history_view_compose_controls.cpp      | 1 +
 Telegram/SourceFiles/ui/controls/compose_ai_button_factory.cpp   | 1 +
 3 files changed, 3 insertions(+)

diff --git a/Telegram/SourceFiles/history/history_widget.cpp b/Telegram/SourceFiles/history/history_widget.cpp
index f82ee13566..67f8cfae2e 100644
--- a/Telegram/SourceFiles/history/history_widget.cpp
+++ b/Telegram/SourceFiles/history/history_widget.cpp
@@ -6259,6 +6259,7 @@ bool HistoryWidget::fieldOrDisabledShown() const {
 }
 
 bool HistoryWidget::hasEnoughLinesForAi() const {
+	return false;
 	if (!_history
 		|| _voiceRecordBar->isActive()
 		|| session().appConfig().aiComposeStyles().empty()) {
diff --git a/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp b/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
index dc997eaa6d..9f1b481e89 100644
--- a/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
+++ b/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
@@ -3641,6 +3641,7 @@ bool ComposeControls::canSendAiComposeDirect() const {
 }
 
 bool ComposeControls::hasEnoughLinesForAi() const {
+	return false;
 	if (!_history
 		|| _recording.current()
 		|| session().appConfig().aiComposeStyles().empty()) {
diff --git a/Telegram/SourceFiles/ui/controls/compose_ai_button_factory.cpp b/Telegram/SourceFiles/ui/controls/compose_ai_button_factory.cpp
index 12df0832a0..02e3763392 100644
--- a/Telegram/SourceFiles/ui/controls/compose_ai_button_factory.cpp
+++ b/Telegram/SourceFiles/ui/controls/compose_ai_button_factory.cpp
@@ -22,6 +22,7 @@ namespace Ui {
 bool HasEnoughLinesForAi(
 		not_null<Main::Session*> session,
 		not_null<Ui::InputField*> field) {
+	return false;
 	if (session->appConfig().aiComposeStyles().empty()) {
 		return false;
 	}
