diff --git a/Telegram/SourceFiles/dialogs/dialogs.style b/Telegram/SourceFiles/dialogs/dialogs.style
index f80f21aa03..1a49f97b53 100644
--- a/Telegram/SourceFiles/dialogs/dialogs.style
+++ b/Telegram/SourceFiles/dialogs/dialogs.style
@@ -99,6 +99,11 @@ defaultDialogRow: DialogRow {
 	textLeft: 68px;
 	textTop: 34px;
 }
+compactDialogRow: DialogRow(defaultDialogRow) {
+	height: 36px;
+	photoSize: 20px;
+	nameLeft: 40px;
+}
 taggedDialogRow: DialogRow(defaultDialogRow) {
 	height: 72px;
 	textTop: 30px;
