 		updateControlsGeometry();
 	}, lifetime());
 
+	Yukigram::Settings::HideBottomBar->changes(
+	) | rpl::on_next([=] {
+		updateControlsVisibility();
+		updateControlsGeometry();
+	}, lifetime());
+
 	_fieldChatStyle = InitMessageField(controller, _field, [=](
 			not_null<DocumentData*> document) {
 		if (_peer && Data::AllowEmojiWithoutPremium(_peer, document)) {
@@ -6459,6 +6466,7 @@ bool HistoryWidget::isBotStart() const {
 	const auto user = _peer ? _peer->asUser() : nullptr;
 	if (!user
 		|| !user->isBot()
+		// || (user->isBlocked() && Yukigram::Settings::HideBottomBar->current())
 		|| !_canSendMessages) {
 		return false;
 	} else if (!user->botInfo->startToken.isEmpty()) {
@@ -6474,10 +6482,16 @@ bool HistoryWidget::isReportMessages() const {
 }
 
 bool HistoryWidget::isBlocked() const {
+	// if (Yukigram::Settings::HideBottomBar->current()) {
+	// 	return false;
+	// }
 	return _peer && _peer->isUser() && _peer->asUser()->isBlocked();
 }
 
 bool HistoryWidget::isJoinChannel() const {
+	if (Yukigram::Settings::HideBottomBar->current()) {
+		return false;
+	}
 	if (const auto channel = _peer ? _peer->asChannel() : nullptr) {
 		return !channel->amIn() && !channel->isMonoforum() && !_canSendMessages;
 	}
@@ -6490,6 +6504,7 @@ bool HistoryWidget::isChoosingTheme() const {
 
 bool HistoryWidget::isMuteUnmute() const {
 	return _peer
+		&& !Yukigram::Settings::HideBottomBar->current()
 		&& ((_peer->isBroadcast() && !_peer->asChannel()->canPostMessages())
 			|| (_peer->isGigagroup() && !Data::CanSendAnything(_peer))
 			|| _peer->isRepliesChat()
