@@ -0,0 +1,127 @@
+#include "settings/sections/settings_yukigram.h"
+
+#include "settings/settings_common_session.h"
+
+#include "base/options.h"
+#include "core/application.h"
+#include "core/yukigram_settings.h"
+#include "lang/lang_keys.h"
+#include "settings/settings_builder.h"
+#include "settings/sections/settings_main.h"
+#include "ui/boxes/confirm_box.h"
+#include "ui/ui_utility.h"
+#include "ui/widgets/buttons.h"
+#include "ui/wrap/vertical_layout.h"
+#include "window/section_widget.h"
+#include "window/window_session_controller.h"
+#include "styles/style_menu_icons.h"
+#include "styles/style_settings.h"
+
+#include <QtGui/QGuiApplication>
+
+namespace Settings {
+
+namespace {
+
+using namespace Builder;
+
+void BuildToggle(SectionBuilder &builder, QStringList &keywords, base::options::option<bool> &option) {
+    const auto controller = builder.controller();
+    if (!controller) {
+        return;
+    }
+
+    const auto name = option.name().isEmpty() ? option.id() : option.name();
+
+    const auto button = builder.addButton({
+		.id = QString("yukigram/%1").arg(option.id()),
+		.title = rpl::single(name),
+		.st = (option.relevant()
+			? &st::settingsButtonNoIcon
+			: &st::settingsOptionDisabled),
+		.toggled = rpl::single(option.value()),
+		.keywords = std::move(keywords),
+	});
+
+    button->toggledValue(
+    ) | rpl::filter([=, &option](bool toggled) {
+        return toggled != option.value();
+    }) | rpl::on_next([=, &option](bool toggled) {
+        if (!option.relevant()) {
+			controller->showToast(
+				tr::lng_settings_experimental_irrelevant(tr::now));
+			return;
+		}
+        option.set(toggled);
+        if (option.restartRequired()) {
+            controller->show(Ui::MakeConfirmBox({
+                .text = tr::lng_settings_need_restart(),
+                .confirmed = [] { Core::Restart(); },
+                .confirmText = tr::lng_settings_restart_now(),
+                .cancelText = tr::lng_settings_restart_later(),
+            }));
+        }
+    }, button->lifetime());
+
+    const auto &description = option.description();
+	if (!description.isEmpty()) {
+	    builder.addSkip(st::settingsCheckboxesSkip);
+        builder.addDividerText(rpl::single(description));
+        builder.addSkip(st::settingsCheckboxesSkip);
+	}
+}
+
+void BuildYukigramSectionContent(SectionBuilder &builder) {
+    const auto addToggle = [&](const char id[], QStringList keywords) {
+        BuildToggle(builder, keywords, base::options::lookup<bool>(id));
+    };
+}
+
+class Yukigram : public Section<Yukigram> {
+public:
+	Yukigram(
+		QWidget *parent,
+		not_null<Window::SessionController*> controller);
+
+	[[nodiscard]] rpl::producer<QString> title() override;
+
+private:
+	void setupContent();
+
+};
+
+const auto kMeta = BuildHelper({
+	.id = Yukigram::Id(),
+	.parentId = MainId(),
+	.title = &tr::lng_settings_section_yukigram,
+	.icon = &st::menuIconSettings,
+}, [](SectionBuilder &builder) {
+	BuildYukigramSectionContent(builder);
+});
+
+const SectionBuildMethod kYukigramSection = kMeta.build;
+
+Yukigram::Yukigram(
+	QWidget *parent,
+	not_null<Window::SessionController*> controller)
+: Section(parent, controller) {
+	setupContent();
+}
+
+rpl::producer<QString> Yukigram::title() {
+	return tr::lng_settings_section_yukigram();
+}
+
+void Yukigram::setupContent() {
+	const auto content = Ui::CreateChild<Ui::VerticalLayout>(this);
+	build(content, kYukigramSection);
+	Ui::ResizeFitChild(this, content);
+}
+
+} // namespace
+
+Type YukigramId() {
+	return Yukigram::Id();
+}
+
+} // namespace Settings
