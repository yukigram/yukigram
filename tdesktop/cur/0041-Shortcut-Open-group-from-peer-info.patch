Subject: [PATCH] (Shortcut) Open group from peer info


diff --git a/Telegram/SourceFiles/info/profile/info_profile_top_bar.cpp b/Telegram/SourceFiles/info/profile/info_profile_top_bar.cpp
index 1dc78f8412..617f5c820f 100644
--- a/Telegram/SourceFiles/info/profile/info_profile_top_bar.cpp
+++ b/Telegram/SourceFiles/info/profile/info_profile_top_bar.cpp
@@ -775,7 +775,12 @@ void TopBar::setupActions(not_null<Window::SessionController*> controller) {
 		_actions->show();
 		_actions->raise();
 	});
-	if (user) {
+	bool showHistoryDone = false;
+	const auto addShowHistory = [&]() {
+		if (showHistoryDone) {
+			return;
+		}
+		showHistoryDone = true;
 		const auto message = Ui::CreateChild<TopBarActionButton>(
 			this,
 			tr::lng_profile_action_short_message(tr::now),
@@ -788,6 +793,9 @@ void TopBar::setupActions(not_null<Window::SessionController*> controller) {
 		message->setAccessibleName(tr::lng_profile_action_short_message(tr::now));
 		buttons.push_back(message);
 		_actions->add(message);
+	};
+	if (user) {
+		addShowHistory();
 	}
 	const auto canJoin = (!sublist && !topic && channel && !channel->amIn());
 	if (canJoin) {
@@ -986,6 +994,13 @@ void TopBar::setupActions(not_null<Window::SessionController*> controller) {
 	if (chechMax()) {
 		return;
 	}
+	if (_peer->id != controller->activeChatCurrent().peer()->id
+		|| controller->dialogsEntryStateCurrent().section == Dialogs::EntryState::Section::Replies) {
+		addShowHistory();
+	}
+	if (chechMax()) {
+		return;
+	}
 	if (!topic
 		&& canJoin
 		&& ((chat && !chat->amCreator() && !chat->hasAdminRights())
