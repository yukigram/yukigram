From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Fri, 3 Apr 2026 04:45:03 +0300
Subject: [PATCH] Always show scheduled messages button

---
 Telegram/SourceFiles/history/history_widget.cpp      | 12 +++++++++++-
 Telegram/SourceFiles/history/history_widget.h        |  3 +++
 .../SourceFiles/settings/settings_experimental.cpp   |  2 ++
 3 files changed, 16 insertions(+), 1 deletion(-)

diff --git a/Telegram/SourceFiles/history/history_widget.cpp b/Telegram/SourceFiles/history/history_widget.cpp
index fe7a9944a6..fd648825da 100644
--- a/Telegram/SourceFiles/history/history_widget.cpp
+++ b/Telegram/SourceFiles/history/history_widget.cpp
@@ -6,6 +6,7 @@ For license and copyright information please follow this link:
 https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 */
 #include "history/history_widget.h"
+#include "base/options.h"
 
 #include "api/api_editing.h"
 #include "api/api_bot.h"
@@ -202,6 +203,15 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include <QtGui/QWindow>
 #include <QtCore/QMimeData>
 
+base::options::toggle AlwaysShowScheduled({
+	.id = kOptionAlwaysShowScheduled,
+	.name = "Always show scheduled messages button",
+	.restartRequired = true,
+});
+
+const char kOptionAlwaysShowScheduled[]
+	= "always-show-scheduled";
+
 namespace {
 
 constexpr auto kMessagesPerPageFirst = 30;
@@ -3352,7 +3362,7 @@ void HistoryWidget::setupScheduledToggle() {
 }
 
 void HistoryWidget::refreshScheduledToggle() {
-	const auto has = _history
+	const auto has = AlwaysShowScheduled.value() || _history
 		&& _canSendMessages
 		&& (session().scheduledMessages().count(_history) > 0);
 	if (!_scheduled && has) {
diff --git a/Telegram/SourceFiles/history/history_widget.h b/Telegram/SourceFiles/history/history_widget.h
index 3f79a66915..e467e39ada 100644
--- a/Telegram/SourceFiles/history/history_widget.h
+++ b/Telegram/SourceFiles/history/history_widget.h
@@ -6,6 +6,9 @@ For license and copyright information please follow this link:
 https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 */
 #pragma once
+#include "base/options.h"
+extern base::options::toggle AlwaysShowScheduled;
+extern const char kOptionAlwaysShowScheduled[];
 
 #include "history/view/controls/history_view_compose_media_edit_manager.h"
 #include "history/view/history_view_corner_buttons.h"
diff --git a/Telegram/SourceFiles/settings/settings_experimental.cpp b/Telegram/SourceFiles/settings/settings_experimental.cpp
index 2dae6059bb..a4ab8c00f1 100644
--- a/Telegram/SourceFiles/settings/settings_experimental.cpp
+++ b/Telegram/SourceFiles/settings/settings_experimental.cpp
@@ -33,6 +33,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "dialogs/ui/dialogs_layout.h"
 #include "history/history_item_components.h"
 #include "info/profile/info_profile_actions.h"
+#include "history/history_widget.h"
 #include "lang/lang_keys.h"
 #include "mainwindow.h"
 #include "mainwidget.h"
@@ -222,6 +223,7 @@ void SetupExperimental(
 	addToggle(kOptionWideMessages);
 	addToggle(Webview::kOptionWebviewDebugEnabled);
 	addToggle(Webview::kOptionWebviewLegacyEdge);
+	addToggle(kOptionAlwaysShowScheduled);
 	addToggle(kOptionAutoScrollInactiveChat);
 	addToggle(Window::Notifications::kOptionHideReplyButton);
 	addToggle(Window::Notifications::kOptionCustomNotification);
-- 
