From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Fri, 15 May 2026 03:17:31 +0300
Subject: [PATCH] (Major) New Supergroup

This patch is adapted from 64Gram.
Original author: c0re100 <corehusky@gmail.com>
---
 Telegram/SourceFiles/window/window_main_menu.cpp         | 9 +++++++++
 .../SourceFiles/window/window_session_controller.cpp     | 4 ++++
 Telegram/SourceFiles/window/window_session_controller.h  | 1 +
 3 files changed, 14 insertions(+)

diff --git a/Telegram/SourceFiles/window/window_main_menu.cpp b/Telegram/SourceFiles/window/window_main_menu.cpp
index e672f011cb..be29b5d4f2 100644
--- a/Telegram/SourceFiles/window/window_main_menu.cpp
+++ b/Telegram/SourceFiles/window/window_main_menu.cpp
@@ -686,6 +686,15 @@ void MainMenu::setupMenu() {
 			}
 		});
 
+		AddMyChannelsBox(addAction(
+			rpl::single(u"New Supergroup"_q),
+			{ &st::menuIconGroups }
+		), controller, true)->addClickHandler([=](Qt::MouseButton which) {
+			if (which == Qt::LeftButton) {
+				controller->showNewSupergroup();
+			}
+		});
+
 		AddMyChannelsBox(addAction(
 			tr::lng_create_channel_title(),
 			{ &st::menuIconChannel }
diff --git a/Telegram/SourceFiles/window/window_session_controller.cpp b/Telegram/SourceFiles/window/window_session_controller.cpp
index 7188aef40a..6c9f827e6c 100644
--- a/Telegram/SourceFiles/window/window_session_controller.cpp
+++ b/Telegram/SourceFiles/window/window_session_controller.cpp
@@ -3198,6 +3198,10 @@ void SessionController::showNewGroup() {
 	_window->show(Box<GroupInfoBox>(this, GroupInfoBox::Type::Group));
 }
 
+void SessionController::showNewSupergroup() {
+	_window->show(Box<GroupInfoBox>(this, GroupInfoBox::Type::Megagroup));
+}
+
 void SessionController::showNewChannel() {
 	_window->show(Box<GroupInfoBox>(this, GroupInfoBox::Type::Channel));
 }
diff --git a/Telegram/SourceFiles/window/window_session_controller.h b/Telegram/SourceFiles/window/window_session_controller.h
index 2889697f8a..0dfcfa2df3 100644
--- a/Telegram/SourceFiles/window/window_session_controller.h
+++ b/Telegram/SourceFiles/window/window_session_controller.h
@@ -581,6 +581,7 @@ public:
 
 	void showAddContact();
 	void showNewGroup();
+	void showNewSupergroup();
 	void showNewChannel();
 
 	void showPassportForm(const Passport::FormRequest &request);
-- 
2.53.0

