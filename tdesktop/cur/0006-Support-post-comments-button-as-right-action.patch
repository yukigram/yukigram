From 262af99dd9fb69dd558b2c796a37d6a408e9e9b0 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Fri, 3 Apr 2026 03:09:38 +0300
Subject: [PATCH 06/28] Support post comments button as right action

---
 .../history/view/history_view_message.cpp     | 27 ++++++++++++++-----
 .../history/view/history_view_message.h       |  2 ++
 .../settings/settings_experimental.cpp        |  2 ++
 3 files changed, 25 insertions(+), 6 deletions(-)

diff --git a/Telegram/SourceFiles/history/view/history_view_message.cpp b/Telegram/SourceFiles/history/view/history_view_message.cpp
index cbf4f8972d..d4c80735cd 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_message.cpp
@@ -6,6 +6,7 @@ For license and copyright information please follow this link:
 https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 */
 #include "history/view/history_view_message.h"
+#include "base/options.h"
 
 #include "api/api_suggest_post.h"
 #include "api/api_transcribes.h"
@@ -134,8 +135,18 @@ struct BadgePillGeometry {
 	};
 }
 
+base::options::toggle CommentsButtonAlwaysRight({
+	.id = kOptionCommentsButtonAlwaysRight,
+	.name = "Move comments button to the right",
+	.description = "Takes place of the share button, but results in more compact channel views",
+	.restartRequired = true,
+});
+
 } // namespace
 
+const char kOptionCommentsButtonAlwaysRight[]
+	= "comments-button-always-right";
+
 struct Message::CommentsButton {
 	std::unique_ptr<Ui::RippleAnimation> ripple;
 	std::vector<UserpicInRow> userpics;
@@ -485,7 +496,7 @@ void Message::animateReaction(Ui::ReactionFlyAnimationArgs &&args) {
 	if (bubble) {
 		// Entry page is always a bubble bottom.
 		auto inner = g;
-		if (_comments) {
+		if (_comments && !displayRightActionComments()) {
 			inner.setHeight(inner.height() - st::historyCommentsButtonHeight);
 		}
 		auto trect = inner.marginsRemoved(st::msgPadding);
@@ -1046,7 +1057,7 @@ void Message::draw(Painter &p, const PaintContext &context) const {
 	const auto customHighlight = mediaDisplayed && media->customHighlight();
 	if (!mediaSelectionIntervals.empty() || customHighlight) {
 		auto localMediaBottom = gForIntervals.top() + gForIntervals.height();
-		if (data()->repliesAreComments() || data()->externalReply()) {
+		if ((data()->repliesAreComments() || data()->externalReply()) && !displayRightActionComments()) {
 			localMediaBottom -= st::historyCommentsButtonHeight;
 		}
 		if (_viewButton) {
@@ -1579,6 +1590,9 @@ void Message::paintCommentsButton(
 	if (!data()->repliesAreComments() && !data()->externalReply()) {
 		return;
 	}
+	if (displayRightActionComments()) {
+		return;
+	}
 	if (!_comments) {
 		_comments = std::make_unique<CommentsButton>();
 		history()->owner().registerHeavyViewPart(const_cast<Message*>(this));
@@ -2280,7 +2294,7 @@ PointState Message::pointState(QPoint point) const {
 			auto mediaOnBottom = (mediaDisplayed && media->isBubbleBottom()) || check || (entry/* && entry->isBubbleBottom()*/);
 			auto mediaOnTop = (mediaDisplayed && media->isBubbleTop()) || (entry && entry->isBubbleTop());
 
-			if (item->repliesAreComments() || item->externalReply()) {
+			if ((item->repliesAreComments() || item->externalReply()) && !displayRightActionComments()) {
 				g.setHeight(g.height() - st::historyCommentsButtonHeight);
 			}
 
@@ -2613,7 +2627,7 @@ BottomRippleMask Message::bottomRippleMask(int buttonHeight) const {
 }
 
 void Message::createCommentsButtonRipple() {
-	auto mask = bottomRippleMask(st::historyCommentsButtonHeight);
+	auto mask = bottomRippleMask(displayRightActionComments() ? 0 : st::historyCommentsButtonHeight);
 	_comments->ripple = std::make_unique<Ui::RippleAnimation>(
 		st::defaultRippleAnimation,
 		std::move(mask.image),
@@ -4412,9 +4426,10 @@ bool Message::displayRightActionComments() const {
 	return !isPinnedContext()
 		&& (context() != Context::SavedSublist)
 		&& data()->repliesAreComments()
+		&& (CommentsButtonAlwaysRight.value() || (true
 		&& media()
 		&& media()->isDisplayed()
-		&& !hasBubble();
+		&& !hasBubble()));
 }
 
 std::optional<QSize> Message::rightActionSize() const {
@@ -5212,7 +5227,7 @@ int Message::resizeContentGetHeight(int newWidth) {
 			newHeight += (bottomInfoHeight - st::msgDateFont->height);
 		}
 
-		if (item->repliesAreComments() || item->externalReply()) {
+		if ((item->repliesAreComments() || item->externalReply()) && !displayRightActionComments()) {
 			newHeight += st::historyCommentsButtonHeight;
 		} else if (_comments) {
 			_comments = nullptr;
diff --git a/Telegram/SourceFiles/history/view/history_view_message.h b/Telegram/SourceFiles/history/view/history_view_message.h
index 24a89991a7..9ea2decff2 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.h
+++ b/Telegram/SourceFiles/history/view/history_view_message.h
@@ -101,6 +101,8 @@ struct BottomRippleMask {
 	int shift = 0;
 };
 
+extern const char kOptionCommentsButtonAlwaysRight[];
+
 class Message final : public Element {
 public:
 	Message(
diff --git a/Telegram/SourceFiles/settings/settings_experimental.cpp b/Telegram/SourceFiles/settings/settings_experimental.cpp
index af2dd0b35c..0b65d03f82 100644
--- a/Telegram/SourceFiles/settings/settings_experimental.cpp
+++ b/Telegram/SourceFiles/settings/settings_experimental.cpp
@@ -15,6 +15,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/wrap/vertical_layout.h"
 #include "ui/wrap/slide_wrap.h"
 #include "ui/widgets/buttons.h"
+#include "history/view/history_view_message.h"
 #include "ui/widgets/labels.h"
 #include "ui/vertical_list.h"
 #include "ui/gl/gl_detection.h"
@@ -235,6 +236,7 @@ void SetupExperimental(
 	addToggle(kModerateCommonGroups);
 	addToggle(kForceComposeSearchOneColumn);
 	addToggle(HistoryView::kOptionDisableAnimoji);
+	addToggle(HistoryView::kOptionCommentsButtonAlwaysRight);
 	addToggle(ChatHelpers::kOptionUnlimitedRecentStickers);
 	addToggle(Ui::kOptionHideAiButton);
 }
-- 
