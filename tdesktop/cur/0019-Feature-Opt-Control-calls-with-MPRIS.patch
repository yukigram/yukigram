@@ -0,0 +1,19 @@
+#include "yukigram/settings/mpris_call_hangup.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *MprisCallHangup = Yukigram::Options::make(kOptionMprisCallHangup, {
+	.name = "Control calls with MPRIS",
+	.description =
+		"Use Prev/Next/Stop to hangup or decline.\n"
+		"Use Play/Pause/PlayPause to accept.\n"
+		"This option conflicts with internal media player controls",
+	.keywords = { u"yukigram"_q, u"mpris"_q, u"hangup"_q, u"call"_q },
+	.category = "system",
+	.restartRequired = true,
+});
+
+const char kOptionMprisCallHangup[] = "mpris-call-hangup";
+
+}
