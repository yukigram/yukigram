From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 28 Apr 2026 02:23:43 +0300
Subject: [PATCH] [UI][Opt] Hide Send As premium channels

---
 Telegram/CMakeLists.txt                             |  2 ++
 Telegram/SourceFiles/main/session/send_as_peers.cpp |  3 +++
 .../yukigram/settings/hide_send_as_premium.cpp      | 13 +++++++++++++
 .../yukigram/settings/hide_send_as_premium.h        |  5 +++++
 4 files changed, 23 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index cd632c72b6..92d0f38dfe 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1901,6 +1901,8 @@ PRIVATE
     yukigram/settings/disable_animoji.h
     yukigram/settings/force_mobile_layout.cpp
     yukigram/settings/force_mobile_layout.h
+    yukigram/settings/hide_send_as_premium.cpp
+    yukigram/settings/hide_send_as_premium.h
     yukigram/settings/hide_wall_paper.cpp
     yukigram/settings/hide_wall_paper.h
     yukigram/settings/icon_theme_symbolic.cpp
diff --git a/Telegram/SourceFiles/main/session/send_as_peers.cpp b/Telegram/SourceFiles/main/session/send_as_peers.cpp
index 86113c3885..8f05412ba4 100644
--- a/Telegram/SourceFiles/main/session/send_as_peers.cpp
+++ b/Telegram/SourceFiles/main/session/send_as_peers.cpp
@@ -11,6 +11,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "data/data_channel.h"
 #include "data/data_session.h"
 #include "data/data_changes.h"
+#include "yukigram/settings/hide_send_as_premium.h"
 #include "main/main_session.h"
 #include "apiwrap.h"
 
@@ -165,11 +166,13 @@ void SendAsPeers::request(SendAsKey key) {
 				const auto &data = as.data();
 				const auto peerId = peerFromMTP(data.vpeer());
 				if (const auto peer = owner.peerLoaded(peerId)) {
+				if (!Yukigram::Settings::HideSendAsPremium->current() || !data.is_premium_required()) {
 					parsed.push_back({
 						.peer = peer,
 						.premiumRequired = data.is_premium_required(),
 					});
 				}
+				}
 			}
 		});
 		if (parsed.size() > 1) {
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.cpp b/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.cpp
new file mode 100644
index 0000000000..e5a6da1a48
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/hide_send_as_premium.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HideSendAsPremium = Yukigram::Options::make(kOptionHideSendAsPremium, {
+	.name = "Hide Send As channels requiring Premium",
+	.keywords = { u"yukigram"_q, u"send"_q, u"channels"_q, u"premium"_q },
+	.restartRequired = true,
+});
+
+const char kOptionHideSendAsPremium[] = "hide-send-as-premium";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.h b/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.h
new file mode 100644
index 0000000000..8c27829b8f
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_send_as_premium.h
@@ -0,0 +1,5 @@
+#include "yukigram/options.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HideSendAsPremium;
+extern const char kOptionHideSendAsPremium[];
+}
-- 
2.53.0

