diff --git a/Telegram/SourceFiles/yukigram/options.cpp b/Telegram/SourceFiles/yukigram/options.cpp
new file mode 100644
index 0000000000..a717736077
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/options.cpp
@@ -0,0 +1,46 @@
+#include "yukigram/options.h"
+
+namespace Yukigram::Options {
+
+std::map<std::string_view, Toggle> toggles;
+
+rpl::variable<bool> *make(const char *key, Description &&d, bool defaultValue) {
+	const auto v = std::make_shared<rpl::variable<bool>>(defaultValue);
+
+	const auto base = std::make_shared<
+		base::options::toggle,
+		base::options::descriptor<bool>
+	>({
+		.id = key,
+		.defaultValue = defaultValue,
+		.restartRequired = d.restartRequired,
+	});
+	rpl::lifetime lifetime;
+
+	toggles[std::string_view(key)] = {
+		.d = std::move(d),
+		.v = v,
+		._base = base,
+		._lifetime = std::move(lifetime),
+	};
+
+	return v.get();
+}
+
+void init() {
+	for (auto &[key, toggle] : toggles) {
+		*toggle.v = toggle._base->value();
+	}
+}
+
+void link() {
+	for (auto &[key, toggle] : toggles) {
+		const auto base = toggle._base;
+		toggle.v->value() | rpl::on_next([=](bool value) {
+			base->set(value);
+		}, toggle._lifetime);
+	}
+}
+
+
+}
diff --git a/Telegram/SourceFiles/yukigram/options.h b/Telegram/SourceFiles/yukigram/options.h
new file mode 100644
index 0000000000..1b75c11d89
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/options.h
@@ -0,0 +1,35 @@
+#pragma once
+
+#include "base/options.h"
+#include "rpl/rpl.h"
+
+#include <QString>
+#include <QStringList>
+#include <map>
+#include <memory>
+#include <string_view>
+
+namespace Yukigram::Options {
+
+struct Description {
+	std::string_view name = "";
+	std::string_view description = "";
+	QStringList keywords = {};
+	bool restartRequired = false;
+};
+
+struct Toggle {
+	Description d;
+	std::shared_ptr<rpl::variable<bool>> v;
+	std::shared_ptr<base::options::toggle> _base;
+	rpl::lifetime _lifetime;
+};
+
+extern std::map<std::string_view, Toggle> toggles;
+
+rpl::variable<bool> *make(const char *key, Description &&d, bool defaultValue = false);
+
+void init();
+void link();
+
+}
