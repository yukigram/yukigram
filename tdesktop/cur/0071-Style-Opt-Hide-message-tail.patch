From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Thu, 7 May 2026 11:11:58 +0300
Subject: [PATCH] (Style)(Opt) Hide message tail

---
 Telegram/CMakeLists.txt                            |  2 ++
 Telegram/Resources/langs/yukigram/en.json          |  2 ++
 .../history/view/history_view_message.cpp          |  2 ++
 .../yukigram/settings/hide_message_tail.cpp        | 14 ++++++++++++++
 .../yukigram/settings/hide_message_tail.h          |  5 +++++
 5 files changed, 25 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_message_tail.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_message_tail.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index ab07601e1c..9b0389f919 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1957,6 +1957,8 @@ PRIVATE
     yukigram/settings/disable_animoji.h
     yukigram/settings/force_mobile_layout.cpp
     yukigram/settings/force_mobile_layout.h
+    yukigram/settings/hide_message_tail.cpp
+    yukigram/settings/hide_message_tail.h
     yukigram/settings/hide_reply_background_emoji.cpp
     yukigram/settings/hide_reply_background_emoji.h
     yukigram/settings/hide_send_as_premium.cpp
diff --git a/Telegram/Resources/langs/yukigram/en.json b/Telegram/Resources/langs/yukigram/en.json
index d5b1c0a537..ae1e591bdf 100644
--- a/Telegram/Resources/langs/yukigram/en.json
+++ b/Telegram/Resources/langs/yukigram/en.json
@@ -38,6 +38,8 @@
     "opt/force-mobile-layout/desc": "",
     "opt/forum-hide-chats-list/name": "Hide narrow column chat list in forums",
     "opt/forum-hide-chats-list/desc": "",
+    "opt/hide-message-tail/name": "Hide message bubble tail",
+    "opt/hide-message-tail/desc": "",
     "opt/hide-reply-background-emoji/name": "Hide reply background emoji",
     "opt/hide-reply-background-emoji/desc": "",
     "opt/hide-send-as/name": "Hide Send As button",
diff --git a/Telegram/SourceFiles/history/view/history_view_message.cpp b/Telegram/SourceFiles/history/view/history_view_message.cpp
index d98af17c2e..743f07df01 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_message.cpp
@@ -30,6 +30,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "history/view/history_view_summary_header.h"
 #include "history/view/history_view_view_button.h" // ViewButton.
 #include "history/history.h"
+#include "yukigram/settings/hide_message_tail.h"
 #include "boxes/premium_preview_box.h"
 #include "boxes/share_box.h"
 #include "boxes/peers/tag_info_box.h"
@@ -5214,6 +5215,7 @@ Ui::BubbleRounding Message::countMessageRounding() const {
 	const auto item = data();
 	const auto keyboard = item->inlineReplyKeyboard();
 	const auto skipTail = smallBottom
+		|| Yukigram::Settings::HideMessageTail->current()
 		|| (media && media->skipBubbleTail())
 		|| (keyboard != nullptr)
 		|| item->isFakeAboutView()
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_message_tail.cpp b/Telegram/SourceFiles/yukigram/settings/hide_message_tail.cpp
new file mode 100644
index 0000000000..565c8c4b53
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_message_tail.cpp
@@ -0,0 +1,14 @@
+#include "yukigram/settings/hide_message_tail.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HideMessageTail = Yukigram::Options::make(kOptionHideMessageTail, {
+	.keywords = { u"yukigram"_q, u"message"_q, u"bubble"_q, u"tail"_q },
+	.category = "style",
+	.restartRequired = true,
+});
+
+const char kOptionHideMessageTail[] = "hide-message-tail";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_message_tail.h b/Telegram/SourceFiles/yukigram/settings/hide_message_tail.h
new file mode 100644
index 0000000000..d7d4b4e793
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_message_tail.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HideMessageTail;
+extern const char kOptionHideMessageTail[];
+}
-- 
