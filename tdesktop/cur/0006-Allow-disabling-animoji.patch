+++ b/Telegram/SourceFiles/yukigram/settings/disable_animoji.h
@@ -0,0 +1,7 @@
+#include "base/options.h"
+namespace Yukigram {
+namespace Settings {
+extern base::options::toggle DisableAnimoji;
+extern const char kOptionDisableAnimoji[];
+}
+}
