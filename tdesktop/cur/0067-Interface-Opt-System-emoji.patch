From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 12 May 2026 12:19:58 +0300
Subject: [PATCH] (Interface)(Opt) System emoji

---
 Telegram/CMakeLists.txt                       |  2 ++
 .../yukigram/settings/system_emoji.cpp        | 20 +++++++++++++++++++
 .../yukigram/settings/system_emoji.h          |  5 +++++
 Telegram/lib_ui/ui/emoji_config.cpp           | 11 ++++++++++
 4 files changed, 38 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/system_emoji.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/system_emoji.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 5dea36a939..b714c8e89a 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1978,6 +1978,8 @@ PRIVATE
     yukigram/settings/star_hide_always.h
     yukigram/settings/star_hide_empty.cpp
     yukigram/settings/star_hide_empty.h
+    yukigram/settings/system_emoji.cpp
+    yukigram/settings/system_emoji.h
     yukigram/settings/time_with_seconds.cpp
     yukigram/settings/time_with_seconds.h
     yukigram/settings/wide_messages.cpp
diff --git a/Telegram/SourceFiles/yukigram/settings/system_emoji.cpp b/Telegram/SourceFiles/yukigram/settings/system_emoji.cpp
new file mode 100644
index 0000000000..7a5f5fd71c
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/system_emoji.cpp
@@ -0,0 +1,20 @@
+#include "yukigram/settings/system_emoji.h"
+#include "yukigram/options.h"
+
+namespace Ui::Emoji {
+extern bool Yukigram_UseSystemEmojiFont;
+}
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *SystemEmoji = Yukigram::Options::make(kOptionSystemEmoji, {
+	.name = "Use system emoji font",
+	.keywords = { u"yukigram"_q, u"system"_q, u"emoji"_q, u"font"_q },
+	.category = "interface",
+}, [](bool value) {
+	Ui::Emoji::Yukigram_UseSystemEmojiFont = value;
+});
+
+const char kOptionSystemEmoji[] = "system-emoji";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/system_emoji.h b/Telegram/SourceFiles/yukigram/settings/system_emoji.h
new file mode 100644
index 0000000000..1bce51908a
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/system_emoji.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *SystemEmoji;
+extern const char kOptionSystemEmoji[];
+}
diff --git a/Telegram/lib_ui/ui/emoji_config.cpp b/Telegram/lib_ui/ui/emoji_config.cpp
index f92235f536..8bbfac1a39 100644
--- a/Telegram/lib_ui/ui/emoji_config.cpp
+++ b/Telegram/lib_ui/ui/emoji_config.cpp
@@ -71,6 +71,7 @@ private:
 
 };
 
+auto EmojiFont = QFont("emoji");
 auto SizeNormal = -1;
 auto SizeLarge = -1;
 auto SpritesCount = -1;
@@ -782,7 +783,17 @@ const QPixmap &SinglePixmap(EmojiPtr emoji, int fontHeight) {
 	).first->second;
 }
 
+extern bool Yukigram_UseSystemEmojiFont = false;
+
 void Draw(QPainter &p, EmojiPtr emoji, int size, int x, int y) {
+	if (Yukigram_UseSystemEmojiFont) {
+		const auto oldFont = p.font();
+		EmojiFont.setPixelSize(size);
+		p.setFont(EmojiFont);
+		p.drawText(QRect(x, y + 1, size + 1, size + 1), emoji->text());
+		p.setFont(oldFont);
+		return;
+	}
 #ifdef Q_OS_MAC
 	const auto s = (style::Scale() == kScaleForTouchBar)
 		? SizeLarge
