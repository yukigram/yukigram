From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Mon, 27 Apr 2026 03:39:34 +0300
Subject: [PATCH] [Fix][Opt] Symbolic tray icon from icon theme

---
 Telegram/CMakeLists.txt                            |  2 ++
 Telegram/SourceFiles/platform/linux/tray_linux.cpp | 13 ++++++++++++-
 .../yukigram/settings/icon_theme_symbolic.cpp      | 14 ++++++++++++++
 .../yukigram/settings/icon_theme_symbolic.h        |  5 +++++
 4 files changed, 33 insertions(+), 1 deletion(-)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 8a672a9c51..3a7167cb68 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1895,6 +1895,8 @@ PRIVATE
     yukigram/options_database.h
     yukigram/options_runtime.h
     yukigram/options.h
+    yukigram/settings/icon_theme_symbolic.cpp
+    yukigram/settings/icon_theme_symbolic.h
     yukigram/settings/mirrored.cpp
     apiwrap.cpp
     apiwrap.h
diff --git a/Telegram/SourceFiles/platform/linux/tray_linux.cpp b/Telegram/SourceFiles/platform/linux/tray_linux.cpp
index d38631679f..80bfc1d48c 100644
--- a/Telegram/SourceFiles/platform/linux/tray_linux.cpp
+++ b/Telegram/SourceFiles/platform/linux/tray_linux.cpp
@@ -17,6 +17,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/widgets/popup_menu.h"
 #include "window/window_controller.h"
 #include "styles/style_window.h"
+#include "yukigram/settings/icon_theme_symbolic.h"
 
 #include <QtCore/QCoreApplication>
 #include <QtWidgets/QMenu>
@@ -30,7 +31,8 @@ namespace {
 using namespace gi::repository;
 
 [[nodiscard]] QString PanelIconName(int counter, bool muted) {
-	return ApplicationIconName() + ((counter > 0)
+	const auto name = Yukigram::Settings::IconThemeSymbolic->current() ? "org.telegram.desktop" : ApplicationIconName();
+	return name + ((counter > 0)
 		? (muted
 			? u"-mute"_q
 			: u"-attention"_q)
@@ -52,6 +54,7 @@ private:
 	struct State {
 		QIcon systemIcon;
 		QString iconThemeName;
+		bool iconThemeSymbolic = false;
 		bool monochrome = false;
 		int32 counter = 0;
 		bool muted = false;
@@ -80,6 +83,7 @@ IconGraphic::~IconGraphic() = default;
 
 QIcon IconGraphic::systemIcon() const {
 	if (_new.iconThemeName == _current.iconThemeName
+		&& _new.iconThemeSymbolic == _current.iconThemeSymbolic
 		&& _new.monochrome == _current.monochrome
 		&& (_new.counter > 0) == (_current.counter > 0)
 		&& _new.muted == _current.muted) {
@@ -122,6 +126,7 @@ QSize IconGraphic::dprSize(const QImage &image) const {
 
 void IconGraphic::updateState() {
 	_new.iconThemeName = QIcon::themeName();
+	_new.iconThemeSymbolic = Yukigram::Settings::IconThemeSymbolic->current();
 	_new.monochrome = Core::App().settings().trayIconMonochrome();
 	_new.counter = Core::App().unreadBadge();
 	_new.muted = Core::App().unreadBadgeMuted();
@@ -131,6 +136,7 @@ void IconGraphic::updateState() {
 bool IconGraphic::isRefreshNeeded() const {
 	return _trayIcon.isNull()
 		|| _new.iconThemeName != _current.iconThemeName
+		|| _new.iconThemeSymbolic != _current.iconThemeSymbolic
 		|| _new.systemIcon.name() != _current.systemIcon.name()
 		|| (isCounterNeeded(_new)
 			? _new.muted != _current.muted
@@ -160,6 +166,7 @@ QIcon IconGraphic::trayIcon() {
 
 		if (currentImageBack.isNull()
 			|| _new.iconThemeName != _current.iconThemeName
+			|| _new.iconThemeSymbolic != _current.iconThemeSymbolic
 			|| _new.systemIcon.name() != _current.systemIcon.name()) {
 			currentImageBack = {};
 
@@ -273,6 +280,10 @@ Tray::Tray() {
 				});
 			});
 	}
+
+	Yukigram::Settings::IconThemeSymbolic->changes() | rpl::on_next([&] {
+		updateIcon();
+	}, _lifetime);
 }
 
 void Tray::createIcon() {
diff --git a/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.cpp b/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.cpp
new file mode 100644
index 0000000000..ad255375ab
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.cpp
@@ -0,0 +1,14 @@
+#include "yukigram/settings/icon_theme_symbolic.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *IconThemeSymbolic = Yukigram::Options::make(kOptionIconThemeSymbolic, {
+    .name = "Use symbolic tray icon from icon theme",
+    .keywords = { u"yukigram"_q, u"tray"_q, u"icon"_q, u"monochrome"_q, u"symbolic"_q },
+    .category = "system",
+});
+
+const char kOptionIconThemeSymbolic[] = "icon-theme-symbolic";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.h b/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.h
new file mode 100644
index 0000000000..b48127f692
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/icon_theme_symbolic.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *IconThemeSymbolic;
+extern const char kOptionIconThemeSymbolic[];
+}
-- 
2.53.0

