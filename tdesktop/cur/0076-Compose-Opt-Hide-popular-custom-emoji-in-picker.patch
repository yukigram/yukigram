From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Wed, 13 May 2026 22:32:24 +0300
Subject: [PATCH] (Compose)(Opt) Hide popular custom emoji in picker

---
 Telegram/CMakeLists.txt                             |  2 ++
 .../SourceFiles/chat_helpers/emoji_list_widget.cpp  |  4 ++++
 .../yukigram/settings/hide_popular_emoji_picker.cpp | 13 +++++++++++++
 .../yukigram/settings/hide_popular_emoji_picker.h   |  5 +++++
 4 files changed, 24 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 93a062b571..a17f5755a1 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1959,6 +1959,8 @@ PRIVATE
     yukigram/settings/force_mobile_layout.h
     yukigram/settings/hide_message_tail.cpp
     yukigram/settings/hide_message_tail.h
+    yukigram/settings/hide_popular_emoji_picker.cpp
+    yukigram/settings/hide_popular_emoji_picker.h
     yukigram/settings/hide_popular_sticker_suggest.cpp
     yukigram/settings/hide_popular_sticker_suggest.h
     yukigram/settings/hide_reply_background_emoji.cpp
diff --git a/Telegram/SourceFiles/chat_helpers/emoji_list_widget.cpp b/Telegram/SourceFiles/chat_helpers/emoji_list_widget.cpp
index dea062d1e5..dbc12debb3 100644
--- a/Telegram/SourceFiles/chat_helpers/emoji_list_widget.cpp
+++ b/Telegram/SourceFiles/chat_helpers/emoji_list_widget.cpp
@@ -50,6 +50,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "main/main_session.h"
 #include "main/main_session_settings.h"
 #include "mainwidget.h"
+#include "yukigram/settings/hide_popular_emoji_picker.h"
 #include "core/core_settings.h"
 #include "core/application.h"
 #include "settings/sections/settings_premium.h"
@@ -3428,6 +3429,9 @@ void EmojiListWidget::refreshCustom() {
 	const auto push = [&](uint64 setId, bool installed) {
 		const auto megagroup = _megagroupSet
 			&& (setId == Data::Stickers::MegagroupSetId);
+		if (Yukigram::Settings::HidePopularEmojiPicker->current() && !installed && !megagroup) {
+			return;
+		}
 		const auto lookupId = megagroup
 			? _megagroupSet->mgInfo->emojiSet.id
 			: setId;
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.cpp b/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.cpp
new file mode 100644
index 0000000000..967136ad8f
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/hide_popular_emoji_picker.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HidePopularEmojiPicker = Yukigram::Options::make(kOptionHidePopularEmojiPicker, {
+	.keywords = { u"yukigram"_q, u"emoji"_q, u"animoji"_q, u"picker"_q, u"popular"_q },
+	.category = "picker",
+});
+
+const char kOptionHidePopularEmojiPicker[] = "hide-popular-emoji-picker";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.h b/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.h
new file mode 100644
index 0000000000..3ba5ef9303
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_popular_emoji_picker.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HidePopularEmojiPicker;
+extern const char kOptionHidePopularEmojiPicker[];
+}
-- 
