From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Wed, 15 Apr 2026 00:05:31 +0300
Subject: [PATCH] Show user type icon in username in chat

This patch is adapted from Kotatogram.
Original author: RadRussianRus <radrussianrus@gmail.com>
---
 .../history/view/history_view_message.cpp     | 47 ++++++++++++++++++-
 Telegram/SourceFiles/ui/chat/chat.style       | 11 +++++
 2 files changed, 57 insertions(+), 1 deletion(-)

diff --git a/Telegram/SourceFiles/history/view/history_view_message.cpp b/Telegram/SourceFiles/history/view/history_view_message.cpp
index 399aad1de8..303056ee2a 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_message.cpp
@@ -72,6 +72,21 @@ const auto kPsaTooltipPrefix = "cloud_lng_tooltip_psa_";
 constexpr auto kFullLineAppearDuration = crl::time(300);
 constexpr auto kLineHeightAppearDuration = crl::time(100);
 
+bool HasChatTypeIcon(HistoryItem *item) {
+	if (!item->isPost() && item->displayFrom()) {
+		const auto from = item->displayFrom();
+		if (from->isChat() || from->isMegagroup() || from->isForum() || from->isChannel()) {
+			return true;
+		} else if (const auto user = from->asUser()) {
+			if (user->isInaccessible()
+				|| (user->isBot() && !user->isSupport() && !user->isRepliesChat())) {
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
 struct SecondRightAction {
 	std::unique_ptr<Ui::RippleAnimation> ripple;
 	ClickHandlerPtr link;
@@ -826,6 +841,9 @@ QSize Message::performCountOptimalSize() {
 				if (Has<RightBadge>()) {
 					namew += st::msgPadding.right() + rightBadgeWidth();
 				}
+				if (HasChatTypeIcon(item)) {
+					namew += st::dialogsChatTypeSkip;
+				}
 				accumulate_max(maxWidth, namew);
 			} else if (via && !displayForwardedFrom()) {
 				accumulate_max(maxWidth, st::msgPadding.left() + via->maxWidth + st::msgPadding.right());
@@ -1727,6 +1745,32 @@ void Message::paintFromName(
 		availableWidth -= st::msgPadding.right() + badgeWidth;
 	}
 
+	const auto chatTypeIcon = [&]() -> std::optional<style::icon> {
+		if (!item->isPost() && item->displayFrom()) {
+			const auto from = item->displayFrom();
+			if (from->isChat() || from->isMegagroup()) {
+				return st::msgNameChatIcon;
+			} else if (from->isChannel()) {
+				return st::msgNameChannelIcon;
+			} else if (from->isForum()) {
+				return st::msgNameForumIcon;
+			} else if (const auto user = from->asUser()) {
+				if (user->isInaccessible()) {
+					return st::msgNameDeletedIcon;
+				} else if (user->isBot() && !user->isSupport() && !user->isRepliesChat()) {
+					return st::msgNameBotIcon;
+				}
+			}
+		}
+		return {};
+	}();
+
+	if (chatTypeIcon) {
+		chatTypeIcon->paint(p, QPoint(availableLeft, trect.top()), availableWidth);
+		availableLeft += chatTypeIcon->width() + st::dialogsChatTypeSkip;
+		availableWidth -= chatTypeIcon->width() + st::dialogsChatTypeSkip;
+	}
+
 	const auto stm = context.messageStyle();
 	const auto from = item->displayFrom();
 	const auto info = from ? nullptr : item->displayHiddenSenderInfo();
@@ -3186,6 +3230,7 @@ bool Message::getStateFromName(
 			availableWidth -= st::msgPadding.right() + badgeWidth;
 		}
 		const auto item = data();
+		const auto chatIconWidth = HasChatTypeIcon(item) ? st::dialogsChatTypeSkip : 0;
 		const auto from = item->displayFrom();
 		const auto nameText = [&]() -> const Ui::Text::String * {
 			if (from) {
@@ -3218,7 +3263,7 @@ bool Message::getStateFromName(
 		}
 		if (point.x() >= availableLeft
 			&& point.x() < availableLeft + availableWidth
-			&& point.x() < availableLeft + nameText->maxWidth()) {
+			&& point.x() < availableLeft + nameText->maxWidth() + chatIconWidth) {
 			outResult->link = fromLink();
 			recordLinkRipplePoint(point, trect.topLeft());
 			_fromLinkRipplePointSet = 1;
diff --git a/Telegram/SourceFiles/ui/chat/chat.style b/Telegram/SourceFiles/ui/chat/chat.style
index b1270a0f0b..5112bf5cf6 100644
--- a/Telegram/SourceFiles/ui/chat/chat.style
+++ b/Telegram/SourceFiles/ui/chat/chat.style
@@ -745,6 +745,17 @@ historyCommentsOpenInSelected: icon {{ "history_comments_open", msgFileThumbLink
 historyCommentsOpenOut: icon {{ "history_comments_open", msgFileThumbLinkOutFg }};
 historyCommentsOpenOutSelected: icon {{ "history_comments_open", msgFileThumbLinkOutFgSelected }};
 
+msgNameBotIcon: icon {{ "dialogs/dialogs_bot", historyPeer4NameFg, point(1px, 3px) }};
+msgNameBotIconSelected: icon {{ "dialogs/dialogs_bot", historyPeer4NameFgSelected, point(1px, 3px) }};
+msgNameChatIcon: icon {{ "dialogs/dialogs_chat", historyPeer4NameFg, point(1px, 4px) }};
+msgNameChatIconSelected: icon {{ "dialogs/dialogs_chat", historyPeer4NameFgSelected, point(1px, 4px) }};
+msgNameChannelIcon: icon {{ "dialogs/dialogs_channel", historyPeer4NameFg, point(3px, 4px) }};
+msgNameChannelIconSelected: icon {{ "dialogs/dialogs_channel", historyPeer4NameFgSelected, point(3px, 4px) }};
+msgNameDeletedIcon: icon {{ "dialogs/dialogs_sending", attentionButtonFg, point(4px, 4px) }};
+msgNameDeletedIconSelected: icon {{ "dialogs/dialogs_sending", attentionButtonFgOver, point(4px, 4px) }};
+msgNameForumIcon: icon {{ "dialogs/dialogs_forum", historyPeer4NameFg, point(1px, 4px) }};
+msgNameForumIconSelected: icon {{ "dialogs/dialogs_forum", historyPeer4NameFgSelected, point(1px, 4px) }};
+
 historyGroupCallUserpics: GroupCallUserpics {
 	size: 32px;
 	shift: 12px;
-- 
2.53.0

