diff --git a/Telegram/build/changelog2appstream.py b/Telegram/build/changelog2appstream.py
index edf349aba6..0da91c7915 100755
--- a/Telegram/build/changelog2appstream.py
+++ b/Telegram/build/changelog2appstream.py
@@ -6,7 +6,7 @@ from xml.etree import ElementTree as ET
 import argparse
 
 def parse_changelog(changelog_path):
-    version_re = re.compile(r'([\d.-]+)\s+(\w+)?\s*\((\d{2}.\d{2}\.\d{2})\)')
+    version_re = re.compile(r'([\d.-]+)\s+([\w.]+)?\s*\((\d{2}.\d{2}\.\d{2})\)')
     entry_re = re.compile(r'-\s(.*)')
 
     with open(changelog_path, "r", encoding="utf-8") as f:
diff --git a/Telegram/cmake/generate_appstream_changelog.cmake b/Telegram/cmake/generate_appstream_changelog.cmake
