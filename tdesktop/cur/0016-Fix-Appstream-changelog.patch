+++ b/Telegram/cmake/generate_appstream_changelog.cmake
@@ -21,7 +21,7 @@ function(generate_appstream_changelog target_name changelog_path metadata_path)
         ${submodules_loc}/build/changelog2appstream.py
         -c "${changelog_path}"
