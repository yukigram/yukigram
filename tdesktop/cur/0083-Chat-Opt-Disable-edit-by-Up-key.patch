From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Sun, 24 May 2026 20:18:16 +0300
Subject: [PATCH] (Chat)(Opt) Disable edit by Up key

This patch is adapted from Kotatogram.
Original author: RadRussianRus <radrussianrus@gmail.com>

diff --git a/Telegram/SourceFiles/history/history_widget.cpp b/Telegram/SourceFiles/history/history_widget.cpp
index 32625856eb..9ce14018ba 100644
--- a/Telegram/SourceFiles/history/history_widget.cpp
+++ b/Telegram/SourceFiles/history/history_widget.cpp
@@ -18,6 +18,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "api/api_unread_things.h"
 #include "base/random.h"
 #include "boxes/compose_ai_box.h"
+#include "yukigram/settings/disable_up_edit.h"
 #include "ui/boxes/confirm_box.h"
 #include "boxes/delete_messages_box.h"
 #include "boxes/send_credits_box.h"
@@ -8085,6 +8086,7 @@ void HistoryWidget::keyPressEvent(QKeyEvent *e) {
 		_scroll->keyPressEvent(e);
 	} else if (e->key() == Qt::Key_Up && !commonModifiers) {
 		if (!_field->empty()
+			|| Yukigram::Settings::DisableUpEdit->current()
 			|| !canWriteMessage()
 			|| _editMsgId
 			|| _replyTo) {
diff --git a/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp b/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
index d55c02e71e..aed1ddbd11 100644
--- a/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
+++ b/Telegram/SourceFiles/history/view/controls/history_view_compose_controls.cpp
@@ -92,6 +92,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "menu/menu_checked_action.h"
 #include "menu/menu_send.h"
 #include "settings/sections/settings_premium.h"
+#include "yukigram/settings/disable_up_edit.h"
 #include "ui/item_text_options.h"
 #include "ui/text/text_options.h"
 #include "ui/text/text_utilities.h"
@@ -2347,7 +2348,7 @@ void ComposeControls::initKeyHandler() {
 			_attachRequests.fire({});
 			return;
 		}
-		if (key == Qt::Key_Up && !hasModifiers) {
+		if (key == Qt::Key_Up && !hasModifiers && !Yukigram::Settings::DisableUpEdit->current()) {
 			if (!isEditingMessage() && _field->empty()) {
 				_editLastMessageRequests.fire(std::move(keyEvent));
 				return;
diff --git a/Telegram/SourceFiles/yukigram/settings/disable_up_edit.cpp b/Telegram/SourceFiles/yukigram/settings/disable_up_edit.cpp
new file mode 100644
index 0000000000..f59f4a8e62
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/disable_up_edit.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/disable_up_edit.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *DisableUpEdit = Yukigram::Options::make<bool>(kOptionDisableUpEdit, {
+	.keywords = { u"yukigram"_q, u"edit"_q, u"up"_q },
+	.category = "chat",
+});
+
+const char kOptionDisableUpEdit[] = "disable-up-edit";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/disable_up_edit.h b/Telegram/SourceFiles/yukigram/settings/disable_up_edit.h
new file mode 100644
index 0000000000..6a4cf57d12
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/disable_up_edit.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *DisableUpEdit;
+extern const char kOptionDisableUpEdit[];
+}
