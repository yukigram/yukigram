From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Sun, 24 May 2026 20:42:59 +0300
Subject: [PATCH] (Info) More info in PeerListBox

---
 Telegram/Resources/langs/yukigram/en.json    | 12 ++++++++++
 Telegram/SourceFiles/boxes/peer_list_box.cpp | 23 +++++++++++++-------
 2 files changed, 27 insertions(+), 8 deletions(-)

diff --git a/Telegram/Resources/langs/yukigram/en.json b/Telegram/Resources/langs/yukigram/en.json
index b92a0f442f..35d3a88a41 100644
--- a/Telegram/Resources/langs/yukigram/en.json
+++ b/Telegram/Resources/langs/yukigram/en.json
@@ -10,6 +10,18 @@
     "box/forward/forward": "Forward to…",
     "box/forward/copy": "Copy to…",
     "box/forward/steal": "Copy media only to…",
+    "box/peer-list/channel-like/broadcast": "channel",
+    "box/peer-list/channel-like/forum": "forum",
+    "box/peer-list/channel-like/monoforum": "monoforum",
+    "box/peer-list/channel-like/supergroup": "supergroup",
+    "box/peer-list/channel-like/unknown": "channel-like",
+    "box/peer-list/group": "legacy group",
+    "box/peer-list/count/members#zero": "{kind}",
+    "box/peer-list/count/members#one": "{kind}, {count} member",
+    "box/peer-list/count/members#other": "{kind}, {count} members",
+    "box/peer-list/count/subscribers#zero": "{kind}",
+    "box/peer-list/count/subscribers#one": "{kind}, {count} subscriber",
+    "box/peer-list/count/subscribers#other": "{kind}, {count} subscribers",
     "box/sticker-set/owner/title": "Owner",
     "drawer/new-supergroup/title": "New supergroup",
     "menu/first-message/title": "First message",
diff --git a/Telegram/SourceFiles/boxes/peer_list_box.cpp b/Telegram/SourceFiles/boxes/peer_list_box.cpp
index c54e1d2199..4535cf881d 100644
--- a/Telegram/SourceFiles/boxes/peer_list_box.cpp
+++ b/Telegram/SourceFiles/boxes/peer_list_box.cpp
@@ -25,8 +25,10 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/painter.h"
 #include "ui/ui_utility.h"
 #include "lang/lang_keys.h"
+#include "yukigram/lang.h"
 #include "storage/file_download.h"
 #include "data/data_peer_values.h"
+#include "data/data_channel.h"
 #include "data/data_chat.h"
 #include "data/data_session.h"
 #include "data/data_changes.h"
@@ -645,18 +647,23 @@ void PeerListRow::refreshStatus() {
 			_statusValidTill = crl::now()
 				+ Data::OnlineChangeTimeout(user, time);
 		}
-	} else if (auto chat = peer()->asChat()) {
+	} else if (const auto chat = peer()->asChat()) {
 		if (!chat->amIn()) {
 			setStatusText(tr::lng_chat_status_unaccessible(tr::now));
-		} else if (chat->count > 0) {
-			setStatusText(tr::lng_chat_status_members(tr::now, lt_count_decimal, chat->count));
 		} else {
-			setStatusText(tr::lng_group_status(tr::now));
+			setStatusText(ktr("box/peer-list/count/members", chat->count, { "kind", ktr("box/peer-list/group") }, { "count", QString::number(chat->count) }));
 		}
-	} else if (peer()->isMegagroup()) {
-		setStatusText(tr::lng_group_status(tr::now));
-	} else if (peer()->isChannel()) {
-		setStatusText(tr::lng_channel_status(tr::now));
+	} else if (const auto channel = peer()->asChannel(); channel->membersCountKnown()) {
+		setStatusText(ktr(
+			channel->isBroadcast() ? "box/peer-list/count/subscribers" : "box/peer-list/count/members",
+			channel->membersCount(),
+			{ "kind", ktr(channel->isMonoforum() ? "box/peer-list/channel-like/monoforum"
+				: channel->isForum() ? "box/peer-list/channel-like/forum"
+				: channel->isMegagroup() ? "box/peer-list/channel-like/supergroup"
+				: channel->isBroadcast() ? "box/peer-list/channel-like/broadcast"
+				: "box/peer-list/channel-like/unknown") },
+			{ "count", QString::number(channel->membersCount()) }
+		));
 	}
 }
 
-- 
2.53.0

