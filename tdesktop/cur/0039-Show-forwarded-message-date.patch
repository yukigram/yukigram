From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Wed, 15 Apr 2026 23:02:59 +0300
Subject: [PATCH] Show forwarded message date

This patch is adapted from Forkgram.
Original author: 23rd <23rd@vivaldi.net>
---
 Telegram/SourceFiles/history/history_item_components.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/Telegram/SourceFiles/history/history_item_components.cpp b/Telegram/SourceFiles/history/history_item_components.cpp
index 45c1f4b7cb..0f8e7f134a 100644
--- a/Telegram/SourceFiles/history/history_item_components.cpp
+++ b/Telegram/SourceFiles/history/history_item_components.cpp
@@ -10,6 +10,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "api/api_text_entities.h"
 #include "base/qt/qt_key_modifiers.h"
 #include "base/options.h"
+#include "base/unixtime.h"
 #include "lang/lang_keys.h"
 #include "ui/effects/ripple_animation.h"
 #include "ui/effects/spoiler_mess.h"
@@ -337,6 +338,9 @@ void HistoryMessageForwarded::create(
 				tr::marked);
 		}
 	}
+	if (originalDate != TimeId(0)) {
+		phrase.append(QString(" on ") + Ui::FormatDateTime(base::unixtime::parse(originalDate)));
+	}
 	text.setMarkedText(st::fwdTextStyle, phrase, kMarkupTextOptions, context);
 
 	text.setLink(1, fromChannel
