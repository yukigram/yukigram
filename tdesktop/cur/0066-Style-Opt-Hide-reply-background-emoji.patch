From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 28 Apr 2026 12:57:40 +0300
Subject: [PATCH] (Style)(Opt) Hide reply background emoji

---
 Telegram/CMakeLists.txt                             |  2 ++
 Telegram/Resources/langs/yukigram/en.json           |  2 ++
 .../SourceFiles/history/view/history_view_reply.cpp |  4 ++++
 .../settings/hide_reply_background_emoji.cpp        | 13 +++++++++++++
 .../yukigram/settings/hide_reply_background_emoji.h |  5 +++++
 5 files changed, 26 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index f430f2b944..ef5ab54870 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1957,6 +1957,8 @@ PRIVATE
     yukigram/settings/disable_animoji.h
     yukigram/settings/force_mobile_layout.cpp
     yukigram/settings/force_mobile_layout.h
+    yukigram/settings/hide_reply_background_emoji.cpp
+    yukigram/settings/hide_reply_background_emoji.h
     yukigram/settings/hide_send_as_premium.cpp
     yukigram/settings/hide_send_as_premium.h
     yukigram/settings/hide_send_as.cpp
diff --git a/Telegram/Resources/langs/yukigram/en.json b/Telegram/Resources/langs/yukigram/en.json
index b74148394d..bd3bac306a 100644
--- a/Telegram/Resources/langs/yukigram/en.json
+++ b/Telegram/Resources/langs/yukigram/en.json
@@ -32,6 +32,8 @@
     "opt/force-mobile-layout/desc": "",
     "opt/forum-hide-chats-list/name": "Hide narrow column chat list in forums",
     "opt/forum-hide-chats-list/desc": "",
+    "opt/hide-reply-background-emoji/name": "Hide reply background emoji",
+    "opt/hide-reply-background-emoji/desc": "",
     "opt/hide-send-as/name": "Hide Send As button",
     "opt/hide-send-as/desc": "",
     "opt/hide-send-as-premium/name": "Hide Send As channels requiring Premium",
diff --git a/Telegram/SourceFiles/history/view/history_view_reply.cpp b/Telegram/SourceFiles/history/view/history_view_reply.cpp
index 6ddb53ad9d..9fbe455fc5 100644
--- a/Telegram/SourceFiles/history/view/history_view_reply.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_reply.cpp
@@ -35,6 +35,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/painter.h"
 #include "ui/power_saving.h"
 #include "window/window_session_controller.h"
+#include "yukigram/settings/hide_reply_background_emoji.h"
 #include "styles/style_chat.h"
 #include "styles/style_dialogs.h"
 #include "styles/style_polls.h"
@@ -270,6 +271,9 @@ void FillBackgroundEmoji(
 		bool quote,
 		const Ui::BackgroundEmojiCache &cache,
 		const QImage &firstGiftFrame) {
+	if (Yukigram::Settings::HideReplyBackgroundEmoji->current()) {
+		return;
+	}
 	p.setClipRect(rect);
 
 	const auto &frames = cache.frames;
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.cpp b/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.cpp
new file mode 100644
index 0000000000..d1202134df
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/hide_reply_background_emoji.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HideReplyBackgroundEmoji = Yukigram::Options::make(kOptionHideReplyBackgroundEmoji, {
+	.keywords = { u"yukigram"_q, u"reply"_q, u"emoji"_q, u"background"_q },
+	.category = "style",
+});
+
+const char kOptionHideReplyBackgroundEmoji[] = "hide-reply-background-emoji";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.h b/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.h
new file mode 100644
index 0000000000..13b957e076
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_reply_background_emoji.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HideReplyBackgroundEmoji;
+extern const char kOptionHideReplyBackgroundEmoji[];
+}
