From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Tue, 21 Apr 2026 20:31:17 +0300
Subject: [PATCH] Hide per-chat wallpaper

---
 Telegram/SourceFiles/core/yukigram_settings.cpp           | 8 ++++++++
 Telegram/SourceFiles/core/yukigram_settings.h             | 3 +++
 Telegram/SourceFiles/data/data_channel.cpp                | 3 ++-
 Telegram/SourceFiles/data/data_user.cpp                   | 3 ++-
 .../SourceFiles/settings/sections/settings_yukigram.cpp   | 1 +
 5 files changed, 16 insertions(+), 2 deletions(-)

diff --git a/Telegram/SourceFiles/core/yukigram_settings.cpp b/Telegram/SourceFiles/core/yukigram_settings.cpp
index 72fb52f1e8..9913b99825 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.cpp
+++ b/Telegram/SourceFiles/core/yukigram_settings.cpp
@@ -61,4 +61,12 @@ base::options::toggle ShowMsgId({
 	.restartRequired = true,
 });
 
+const char kOptionHideWallPaper[] = "hide-wall-paper";
+base::options::toggle HideWallPaper({
+	.id = kOptionHideWallPaper,
+	.name = "Hide per-chat wallpaper",
+	.description = "Enforce theme wallpaper instead of peer wallpaper",
+	.restartRequired = true,
+});
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/core/yukigram_settings.h b/Telegram/SourceFiles/core/yukigram_settings.h
index e6cdc4d900..10446a68bc 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.h
+++ b/Telegram/SourceFiles/core/yukigram_settings.h
@@ -28,4 +28,7 @@ extern base::options::toggle TimeWithSeconds;
 extern const char kOptionShowMsgId[];
 extern base::options::toggle ShowMsgId;
 
+extern const char kOptionHideWallPaper[];
+extern base::options::toggle HideWallPaper;
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/data/data_channel.cpp b/Telegram/SourceFiles/data/data_channel.cpp
index 4aee47b812..5b358c9ef1 100644
--- a/Telegram/SourceFiles/data/data_channel.cpp
+++ b/Telegram/SourceFiles/data/data_channel.cpp
@@ -31,6 +31,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "main/session/send_as_peers.h"
 #include "base/unixtime.h"
 #include "core/application.h"
+#include "core/yukigram_settings.h"
 #include "history/history.h"
 #include "history/history_item.h"
 #include "api/api_chat_invite.h"
@@ -1470,7 +1471,7 @@ void ApplyChannelUpdate(
 		session->sendAsPeers().setChosen(channel, PeerId());
 	}
 
-	if (const auto paper = update.vwallpaper()) {
+	if (const auto paper = update.vwallpaper(); paper && !Core::YukigramSettings::HideWallPaper.value()) {
 		channel->setWallPaper(
 			Data::WallPaper::Create(&channel->session(), *paper));
 	} else {
diff --git a/Telegram/SourceFiles/data/data_user.cpp b/Telegram/SourceFiles/data/data_user.cpp
index 2a5c93abdb..713d2b1923 100644
--- a/Telegram/SourceFiles/data/data_user.cpp
+++ b/Telegram/SourceFiles/data/data_user.cpp
@@ -14,6 +14,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "api/api_text_entities.h"
 #include "base/timer_rpl.h"
 #include "core/application.h"
+#include "core/yukigram_settings.h"
 #include "storage/localstorage.h"
 #include "storage/storage_account.h"
 #include "storage/storage_user_photos.h"
@@ -992,7 +993,7 @@ void ApplyUserUpdate(not_null<UserData*> user, const MTPDuserFull &update) {
 		}
 	}
 
-	if (const auto paper = update.vwallpaper()) {
+	if (const auto paper = update.vwallpaper(); paper && !Core::YukigramSettings::HideWallPaper.value()) {
 		user->setWallPaper(
 			Data::WallPaper::Create(&user->session(), *paper),
 			update.is_wallpaper_overridden());
diff --git a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
index 1b2c9d5750..4cedde077e 100644
--- a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
+++ b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
@@ -84,6 +84,7 @@ void BuildYukigramSectionContent(SectionBuilder &builder) {
 	addToggle(Core::YukigramSettings::kOptionAlwaysShowScheduled, { u"yukigram"_q, u"show"_q, u"scheduled"_q, u"messages"_q });
 	addToggle(Core::YukigramSettings::kOptionTimeWithSeconds, { u"yukigram"_q, u"time"_q, u"seconds"_q });
 	addToggle(Core::YukigramSettings::kOptionShowMsgId, { u"yukigram"_q, u"message"_q, u"id"_q });
+	addToggle(Core::YukigramSettings::kOptionHideWallPaper, { u"yukigram"_q, u"hide"_q, u"wallpaper"_q });
 }
 
 class Yukigram : public Section<Yukigram> {
-- 
