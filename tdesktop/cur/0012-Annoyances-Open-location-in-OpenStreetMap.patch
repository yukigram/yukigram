Date: Fri, 3 Apr 2026 03:18:36 +0300
Subject: [PATCH] [Annoyances] Open location in OpenStreetMap

---
 .../SourceFiles/history/history_location_manager.cpp     | 9 +++------
 1 file changed, 3 insertions(+), 6 deletions(-)

diff --git a/Telegram/SourceFiles/history/history_location_manager.cpp b/Telegram/SourceFiles/history/history_location_manager.cpp
index 6cf1ecfddd..99a266be72 100644
--- a/Telegram/SourceFiles/history/history_location_manager.cpp
+++ b/Telegram/SourceFiles/history/history_location_manager.cpp
@@ -33,10 +33,7 @@ void LocationClickHandler::setup() {
 }
 
 QString LocationClickHandler::Url(const Data::LocationPoint &point) {
-	const auto latlon = point.latAsString() + ',' + point.lonAsString();
-	return u"https://maps.google.com/maps?q="_q
-		+ latlon
-		+ u"&ll="_q
-		+ latlon
-		+ u"&z=16"_q;
+	const auto lat = point.latAsString();
+	const auto lon = point.lonAsString();
+	return u"https://www.openstreetmap.org/?mlat="_q + lat + u"&mlon="_q + lon + u"#map=16/"_q + lat + u"/"_q + lon;
 }
