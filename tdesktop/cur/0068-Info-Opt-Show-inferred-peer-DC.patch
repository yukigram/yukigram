From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 5 May 2026 22:35:17 +0300
Subject: [PATCH] (Info)(Opt) Show inferred peer DC

---
 Telegram/CMakeLists.txt                       |  2 ++
 .../info/profile/info_profile_actions.cpp     | 20 +++++++++++++++++++
 .../yukigram/settings/inferred_peer_dc.cpp    | 13 ++++++++++++
 .../yukigram/settings/inferred_peer_dc.h      |  5 +++++
 4 files changed, 40 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 45359e8e00..9e9702eec0 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1967,6 +1967,8 @@ PRIVATE
     yukigram/settings/hide_wall_paper.h
     yukigram/settings/history_peer_type_icons.cpp
     yukigram/settings/history_peer_type_icons.h
+    yukigram/settings/inferred_peer_dc.cpp
+    yukigram/settings/inferred_peer_dc.h
     yukigram/settings/icon_theme_symbolic.cpp
     yukigram/settings/icon_theme_symbolic.h
     yukigram/settings/mirrored.cpp
diff --git a/Telegram/SourceFiles/info/profile/info_profile_actions.cpp b/Telegram/SourceFiles/info/profile/info_profile_actions.cpp
index af61dc2c0a..9788d4ff76 100644
--- a/Telegram/SourceFiles/info/profile/info_profile_actions.cpp
+++ b/Telegram/SourceFiles/info/profile/info_profile_actions.cpp
@@ -41,6 +41,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "data/data_forum.h"
 #include "data/data_forum_topic.h"
 #include "data/data_peer_values.h"
+#include "data/data_photo.h"
 #include "data/data_saved_sublist.h"
 #include "data/data_session.h"
 #include "data/data_user.h"
@@ -101,6 +102,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "window/window_peer_menu.h"
 #include "window/window_separate_id.h"
 #include "window/window_session_controller.h"
+#include "yukigram/settings/inferred_peer_dc.h"
 #include "styles/style_boxes.h"
 #include "styles/style_channel_earn.h" // st::channelEarnCurrencyCommonMargins
 #include "styles/style_info.h"
@@ -1580,6 +1582,22 @@ Section DetailsFiller::makeInfo() {
 			);
 		}
 	};
+	const auto setupPeerDc = [&] {
+		if (Yukigram::Settings::InferredPeerDc->current()) {
+			if (const auto id = _peer->userpicPhotoId()) {
+				if (const auto photo = _peer->owner().photo(id)) {
+					if (const auto dc = photo->mediaKey().first & 0xFFFF'FFFF) {
+						using namespace Ui::Text;
+						addInfoOneLine(
+							rktr("info/peer-dc/inferred"),
+							rpl::single(WithEntities(u"DC%1"_q.arg(dc))),
+							QString()
+						);
+					}
+				}
+			}
+		}
+	};
 	const auto setupJoinDate = [&] {
 		if (ShowChannelJoinedBelowAbout.value()) {
 			if (const auto channel = _peer->asChannel()) {
@@ -1683,6 +1701,7 @@ Section DetailsFiller::makeInfo() {
 		});
 
 		setupPeerId();
+		setupPeerDc();
 
 		if (!user->isBot()) {
 			tracker.track(result->add(
@@ -1804,6 +1823,7 @@ Section DetailsFiller::makeInfo() {
 		}
 
 		setupPeerId();
+		setupPeerDc();
 		setupJoinDate();
 	}
 	raw->toggleOn(tracker.atLeastOneShownValue());
diff --git a/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.cpp b/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.cpp
new file mode 100644
index 0000000000..6b129749d5
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/inferred_peer_dc.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *InferredPeerDc = Yukigram::Options::make<bool>(kOptionInferredPeerDc, {
+	.keywords = { u"yukigram"_q, u"inferred"_q, u"peer"_q, u"dc"_q, u"datacenter"_q },
+	.category = "info",
+});
+
+const char kOptionInferredPeerDc[] = "inferred-peer-dc";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.h b/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.h
new file mode 100644
index 0000000000..5e9df1c406
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/inferred_peer_dc.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *InferredPeerDc;
+extern const char kOptionInferredPeerDc[];
+}
-- 
