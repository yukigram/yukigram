 #include "main/main_session.h"
 #include "chat_helpers/stickers_emoji_pack.h"
@@ -1544,7 +1545,7 @@ void Element::refreshMedia(Element *replacing) {
 		const auto emoji = isolatedEmoji();
 		const auto emojiStickers = &history()->session().emojiStickersPack();
 		const auto skipPremiumEffect = false;
-		if (const auto sticker = emojiStickers->stickerForEmoji(emoji)) {
+		if (const auto sticker = emojiStickers->stickerForEmoji(emoji); sticker && (!Core::YukigramSettings::DisableAnimoji.value())) {
 			auto content = std::make_unique<Sticker>(
 				this,
 				sticker.document,
diff --git a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
index c07ec57a3e..3bc7adf6fe 100644
--- a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
+++ b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
@@ -75,6 +75,8 @@ void BuildYukigramSectionContent(SectionBuilder &builder) {
     const auto addToggle = [&](const char id[], QStringList keywords) {
         BuildToggle(builder, keywords, base::options::lookup<bool>(id));
     };
+
+    addToggle(Core::YukigramSettings::kOptionDisableAnimoji, { u"yukigram"_q, u"disable"_q, u"animoji"_q });
 }
 
 class Yukigram : public Section<Yukigram> {
