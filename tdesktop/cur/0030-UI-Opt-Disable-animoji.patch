diff --git a/Telegram/SourceFiles/yukigram/settings/disable_animoji.cpp b/Telegram/SourceFiles/yukigram/settings/disable_animoji.cpp
new file mode 100644
index 0000000000..f6a9e96e14
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/disable_animoji.cpp
@@ -0,0 +1,15 @@
+#include "yukigram/settings/disable_animoji.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *DisableAnimoji = Yukigram::Options::make(kOptionDisableAnimoji, {
+	.name = "Disable animated big emoji",
+	.keywords = { u"yukigram"_q, u"animoji"_q, u"emoji"_q },
+	.category = "history",
+	.restartRequired = true,
+});
+
+const char kOptionDisableAnimoji[] = "disable-animoji";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/disable_animoji.h b/Telegram/SourceFiles/yukigram/settings/disable_animoji.h
