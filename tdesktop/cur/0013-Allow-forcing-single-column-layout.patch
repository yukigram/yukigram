From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Fri, 3 Apr 2026 03:16:20 +0300
Subject: [PATCH] Allow forcing single-column layout

---
 Telegram/CMakeLists.txt                              |  2 ++
 Telegram/SourceFiles/mainwidget.cpp                  |  3 ++-
 .../SourceFiles/settings/settings_experimental.cpp   |  1 +
 Telegram/SourceFiles/window/window_adaptive.cpp      |  3 ++-
 .../SourceFiles/window/window_session_controller.cpp |  2 ++
 .../yukigram/settings/force_mobile_layout.cpp        | 12 ++++++++++++
 .../yukigram/settings/force_mobile_layout.h          |  5 +++++
 7 files changed, 26 insertions(+), 2 deletions(-)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/force_mobile_layout.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/force_mobile_layout.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index f93fd64eef..130d0f024d 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1895,6 +1895,8 @@ PRIVATE
     yukigram/options.h
     yukigram/settings/disable_animoji.cpp
     yukigram/settings/disable_animoji.h
+    yukigram/settings/force_mobile_layout.cpp
+    yukigram/settings/force_mobile_layout.h
     yukigram/settings/mpris_call_hangup.cpp
     yukigram/settings/mpris_call_hangup.h
     yukigram/settings/right_action_comments.cpp
diff --git a/Telegram/SourceFiles/mainwidget.cpp b/Telegram/SourceFiles/mainwidget.cpp
index beac8028dd..3928beb9e2 100644
--- a/Telegram/SourceFiles/mainwidget.cpp
+++ b/Telegram/SourceFiles/mainwidget.cpp
@@ -36,6 +36,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/text/text_utilities.h"
 #include "ui/toast/toast.h"
 #include "ui/ui_utility.h"
+#include "yukigram/settings/force_mobile_layout.h"
 #include "window/window_connecting_widget.h"
 #include "window/window_top_bar_wrap.h"
 #include "window/notifications_manager.h"
@@ -2866,7 +2867,7 @@ void MainWidget::updateWindowAdaptiveLayout() {
 
 	// Check if we are in a single-column layout in a wide enough window
 	// for the normal layout. If so, switch to the normal layout.
-	if (layout.windowLayout == Window::Adaptive::WindowLayout::OneColumn) {
+	if ((!Yukigram::Settings::ForceMobileLayout->current()) && layout.windowLayout == Window::Adaptive::WindowLayout::OneColumn) {
 		auto chatWidth = layout.chatWidth;
 		//if (session().settings().tabbedSelectorSectionEnabled()
 		//	&& chatWidth >= _history->minimalWidthForTabbedSelectorSection()) {
diff --git a/Telegram/SourceFiles/settings/settings_experimental.cpp b/Telegram/SourceFiles/settings/settings_experimental.cpp
index d20f877e0d..53e4d6d2b2 100644
--- a/Telegram/SourceFiles/settings/settings_experimental.cpp
+++ b/Telegram/SourceFiles/settings/settings_experimental.cpp
@@ -38,6 +38,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "mtproto/session_private.h"
 #include "webview/webview_embed.h"
 #include "window/main_window.h"
+#include "window/window_adaptive.h"
 #include "window/window_peer_menu.h"
 #include "window/window_session_controller.h"
 #include "window/window_controller.h"
diff --git a/Telegram/SourceFiles/window/window_adaptive.cpp b/Telegram/SourceFiles/window/window_adaptive.cpp
index 784164db99..6586692775 100644
--- a/Telegram/SourceFiles/window/window_adaptive.cpp
+++ b/Telegram/SourceFiles/window/window_adaptive.cpp
@@ -8,6 +8,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "window/window_adaptive.h"
 
 #include "history/history_item.h"
+#include "yukigram/settings/force_mobile_layout.h"
 #include "data/data_media_types.h"
 #include "data/data_session.h"
 #include "core/application.h"
@@ -18,7 +19,7 @@ namespace Window {
 Adaptive::Adaptive() = default;
 
 void Adaptive::setWindowLayout(WindowLayout value) {
-	_layout = value;
+	_layout = (Yukigram::Settings::ForceMobileLayout->current() ? WindowLayout::OneColumn : value);
 }
 
 void Adaptive::setChatLayout(ChatLayout value) {
diff --git a/Telegram/SourceFiles/window/window_session_controller.cpp b/Telegram/SourceFiles/window/window_session_controller.cpp
index 9f1fa45258..897ed90b28 100644
--- a/Telegram/SourceFiles/window/window_session_controller.cpp
+++ b/Telegram/SourceFiles/window/window_session_controller.cpp
@@ -87,6 +87,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/effects/message_sending_animation_controller.h"
 #include "ui/style/style_palette_colorizer.h"
 #include "ui/toast/toast.h"
+#include "yukigram/settings/force_mobile_layout.h"
 #include "calls/calls_instance.h" // Core::App().calls().inCall().
 #include "calls/group/calls_group_call.h"
 #include "calls/group/calls_group_common.h"
@@ -2492,6 +2493,7 @@ auto SessionController::computeColumnLayout() const -> ColumnLayout {
 	auto dialogsWidth = 0, chatWidth = 0, thirdWidth = 0;
 
 	auto useOneColumnLayout = [&] {
+		if (Yukigram::Settings::ForceMobileLayout->current()) return true;
 		auto minimalNormal = st::columnMinimalWidthLeft
 			+ st::columnMinimalWidthMain;
 		if (_hasDialogs && bodyWidth < minimalNormal) {
diff --git a/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.cpp b/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.cpp
new file mode 100644
index 0000000000..4a87d93ff1
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.cpp
@@ -0,0 +1,12 @@
+#include "yukigram/settings/force_mobile_layout.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *ForceMobileLayout = Yukigram::Options::make(kOptionForceMobileLayout, {
+	.name = "Force single-column layout",
+	.keywords = { u"yukigram"_q, u"layout"_q, u"small"_q, u"phone"_q, u"mobile"_q },
+});
+
+const char kOptionForceMobileLayout[] = "force-mobile-layout";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.h b/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.h
new file mode 100644
index 0000000000..d47753c42e
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/force_mobile_layout.h
@@ -0,0 +1,5 @@
+#include "yukigram/options.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *ForceMobileLayout;
+extern const char kOptionForceMobileLayout[];
+}
