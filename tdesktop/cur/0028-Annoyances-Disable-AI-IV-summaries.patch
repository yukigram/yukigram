From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 12 May 2026 01:21:33 +0300
Subject: [PATCH] (Annoyances) Disable AI IV summaries

---
 Telegram/SourceFiles/iv/iv_rich_page.cpp | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/Telegram/SourceFiles/iv/iv_rich_page.cpp b/Telegram/SourceFiles/iv/iv_rich_page.cpp
index afaff04733..b7708d9061 100644
--- a/Telegram/SourceFiles/iv/iv_rich_page.cpp
+++ b/Telegram/SourceFiles/iv/iv_rich_page.cpp
@@ -1102,7 +1102,9 @@ void AppendBlock(
 		AdoptAnchor(&parsed.anchorId, &parsed.text);
 		parsed.caption = ParseRichText(data.vcaption(), context);
 		AdoptAnchor(&parsed.anchorId, &parsed.caption);
-		result->push_back(std::move(parsed));
+		if (parsed.caption.text != TextWithEntities{"Cocoon AI Summary"}) {
+			result->push_back(std::move(parsed));
+		}
 	}, [&](const MTPDpageBlockBlockquoteBlocks &data) {
 		auto parsed = MakeBlock(BlockKind::Quote);
 		AppendBlocks(data.vblocks().v, &parsed.blocks, context);
