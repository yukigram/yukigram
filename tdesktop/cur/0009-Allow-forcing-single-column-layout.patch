From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Fri, 3 Apr 2026 03:16:20 +0300
Subject: [PATCH] Allow forcing single-column layout

---
 Telegram/SourceFiles/mainwidget.cpp                 |  2 +-
 .../SourceFiles/settings/settings_experimental.cpp  |  2 ++
 Telegram/SourceFiles/window/window_adaptive.cpp     | 13 ++++++++++++-
 Telegram/SourceFiles/window/window_adaptive.h       |  4 ++++
 .../window/window_session_controller.cpp            |  1 +
 5 files changed, 20 insertions(+), 2 deletions(-)

diff --git a/Telegram/SourceFiles/mainwidget.cpp b/Telegram/SourceFiles/mainwidget.cpp
index 38cd8a033d..3f2c1b741e 100644
--- a/Telegram/SourceFiles/mainwidget.cpp
+++ b/Telegram/SourceFiles/mainwidget.cpp
@@ -2855,7 +2855,7 @@ void MainWidget::updateWindowAdaptiveLayout() {
 
 	// Check if we are in a single-column layout in a wide enough window
 	// for the normal layout. If so, switch to the normal layout.
-	if (layout.windowLayout == Window::Adaptive::WindowLayout::OneColumn) {
+	if ((!Window::ForceMobileLayout.value()) && layout.windowLayout == Window::Adaptive::WindowLayout::OneColumn) {
 		auto chatWidth = layout.chatWidth;
 		//if (session().settings().tabbedSelectorSectionEnabled()
 		//	&& chatWidth >= _history->minimalWidthForTabbedSelectorSection()) {
diff --git a/Telegram/SourceFiles/settings/settings_experimental.cpp b/Telegram/SourceFiles/settings/settings_experimental.cpp
index 97066cbcff..f588c05c07 100644
--- a/Telegram/SourceFiles/settings/settings_experimental.cpp
+++ b/Telegram/SourceFiles/settings/settings_experimental.cpp
@@ -39,6 +39,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "mtproto/session_private.h"
 #include "webview/webview_embed.h"
 #include "window/main_window.h"
+#include "window/window_adaptive.h"
 #include "window/window_peer_menu.h"
 #include "window/window_session_controller.h"
 #include "history/view/history_view_element.h"
@@ -234,6 +235,7 @@ void SetupExperimental(
 		addToggle(kOptionFastButtonsMode);
 	}
 	addToggle(Window::kOptionDisableTouchbar);
+	addToggle(Window::kOptionForceMobileLayout);
 	addToggle(Info::kAlternativeScrollProcessing);
 	addToggle(kModerateCommonGroups);
 	addToggle(kForceComposeSearchOneColumn);
diff --git a/Telegram/SourceFiles/window/window_adaptive.cpp b/Telegram/SourceFiles/window/window_adaptive.cpp
index 784164db99..f09331375a 100644
--- a/Telegram/SourceFiles/window/window_adaptive.cpp
+++ b/Telegram/SourceFiles/window/window_adaptive.cpp
@@ -6,6 +6,7 @@ For license and copyright information please follow this link:
 https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 */
 #include "window/window_adaptive.h"
+#include "base/options.h"
 
 #include "history/history_item.h"
 #include "data/data_media_types.h"
@@ -15,10 +16,20 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 
 namespace Window {
 
+base::options::toggle ForceMobileLayout({
+	.id = kOptionForceMobileLayout,
+	.name = "Force mobile-like layout",
+	.description = "Always use one-column layout. Useful for PostmarketOS users",
+	.restartRequired = true,
+});
+
+const char kOptionForceMobileLayout[]
+	= "force-mobile-layout";
+
 Adaptive::Adaptive() = default;
 
 void Adaptive::setWindowLayout(WindowLayout value) {
-	_layout = value;
+	_layout = (ForceMobileLayout.value() ? WindowLayout::OneColumn : value);
 }
 
 void Adaptive::setChatLayout(ChatLayout value) {
diff --git a/Telegram/SourceFiles/window/window_adaptive.h b/Telegram/SourceFiles/window/window_adaptive.h
index 9a6421e312..aff3aedddd 100644
--- a/Telegram/SourceFiles/window/window_adaptive.h
+++ b/Telegram/SourceFiles/window/window_adaptive.h
@@ -6,9 +6,13 @@ For license and copyright information please follow this link:
 https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 */
 #pragma once
+#include "base/options.h"
 
 namespace Window {
 
+extern base::options::toggle ForceMobileLayout;
+extern const char kOptionForceMobileLayout[];
+
 class Adaptive {
 public:
 	enum class WindowLayout {
diff --git a/Telegram/SourceFiles/window/window_session_controller.cpp b/Telegram/SourceFiles/window/window_session_controller.cpp
index d9c24641e9..613e77e437 100644
--- a/Telegram/SourceFiles/window/window_session_controller.cpp
+++ b/Telegram/SourceFiles/window/window_session_controller.cpp
@@ -2486,6 +2486,7 @@ auto SessionController::computeColumnLayout() const -> ColumnLayout {
 	auto dialogsWidth = 0, chatWidth = 0, thirdWidth = 0;
 
 	auto useOneColumnLayout = [&] {
+		if (Window::ForceMobileLayout.value()) return true;
 		auto minimalNormal = st::columnMinimalWidthLeft
 			+ st::columnMinimalWidthMain;
 		if (_hasDialogs && bodyWidth < minimalNormal) {
