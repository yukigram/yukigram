Subject: [PATCH] Mirror select Experimental settings

---
 Telegram/CMakeLists.txt                       |  1 +
 .../yukigram/settings/mirrored.cpp            | 69 +++++++++++++++++++
 2 files changed, 70 insertions(+)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/mirrored.cpp

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index ba6a367cef..583adabc79 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1907,6 +1907,7 @@ PRIVATE
     yukigram/options_database.h
     yukigram/options_runtime.h
     yukigram/options.h
+    yukigram/settings/mirrored.cpp
     apiwrap.cpp
     apiwrap.h
     config.h
diff --git a/Telegram/SourceFiles/yukigram/settings/mirrored.cpp b/Telegram/SourceFiles/yukigram/settings/mirrored.cpp
new file mode 100644
index 0000000000..3afd74d793
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/mirrored.cpp
@@ -0,0 +1,69 @@
+#include "yukigram/options.h"
+#include "chat_helpers/tabbed_panel.h"
+#include "chat_helpers/stickers_list_widget.h"
+#include "dialogs/dialogs_widget.h"
+#include "info/profile/info_profile_actions.h"
+#include "mainwidget.h"
+#include "window/window_peer_menu.h"
+#include "ui/chat/chat_style_radius.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *TabbedPanelShowOnClick = Yukigram::Options::make(ChatHelpers::kOptionTabbedPanelShowOnClick, {
+	.name = "Click to show emoji picker",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"tabbed"_q, u"panel"_q, u"stickers"_q, u"gifs"_q, u"emoji"_q, u"hover"_q },
+	.category = "picker",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *UnlimitedRecentStickers = Yukigram::Options::make(ChatHelpers::kOptionUnlimitedRecentStickers, {
+	.name = "Unlimited recent stickers",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"stickers"_q, u"limit"_q, u"unlimited"_q },
+	.category = "picker",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *ForumHideChatsList = Yukigram::Options::make(Dialogs::kOptionForumHideChatsList, {
+	.name = "Hide narrow column chat list in forums",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"forums"_q, u"chat list"_q, u"column"_q },
+	.category = "dialogs",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *ShowPeerIdBelowAbout = Yukigram::Options::make(Info::Profile::kOptionShowPeerIdBelowAbout, {
+	.name = "Show peer ID",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"peer"_q, u"id"_q },
+	.category = "tweaks",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *ShowChannelJoinedBelowAbout = Yukigram::Options::make(Info::Profile::kOptionShowChannelJoinedBelowAbout, {
+	.name = "Show channel join date",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"channel"_q, u"join"_q, u"date"_q },
+	.category = "tweaks",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *ForceComposeSearchOneColumn = Yukigram::Options::make(kForceComposeSearchOneColumn, {
+	.name = "Embedded search in single-column",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"embedded"_q, u"search"_q, u"chat"_q, u"column"_q, u"layout"_q, u"mobile"_q, u"phone"_q },
+	.category = "interface",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *ViewProfileInChatsListContextMenu = Yukigram::Options::make(Window::kOptionViewProfileInChatsListContextMenu, {
+	.name = "View profile button in context menu",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"profile"_q, u"chat list"_q, u"context"_q, u"menu"_q },
+	.category = "dialogs",
+	.mirrorExperimental = true,
+});
+
+rpl::variable<bool> *UseSmallMsgBubbleRadius = Yukigram::Options::make(Ui::kOptionUseSmallMsgBubbleRadius, {
+	.name = "Use small message bubble radius",
+	.keywords = { u"yukigram"_q, u"experimental"_q, u"round"_q, u"radius"_q, u"corner"_q, u"bubble"_q },
+	.category = "history",
+	.restartRequired = true,
+	.mirrorExperimental = true,
+});
+
+}
