diff --git a/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp
new file mode 100644
index 0000000000..8e13e0ea79
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/hide_popular_sticker_suggest.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HidePopularStickerSuggest = Yukigram::Options::make(kOptionHidePopularStickerSuggest, {
+	.keywords = { u"yukigram"_q, u"stickers"_q, u"suggested"_q, u"pack"_q, u"popular"_q },
+	.category = "compose",
+});
+
+const char kOptionHidePopularStickerSuggest[] = "hide-popular-sticker-suggest";
+
+}
