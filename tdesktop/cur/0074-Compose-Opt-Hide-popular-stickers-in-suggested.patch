Subject: [PATCH] (Compose)(Opt) Hide popular stickers in suggested


diff --git a/Telegram/SourceFiles/chat_helpers/field_autocomplete.cpp b/Telegram/SourceFiles/chat_helpers/field_autocomplete.cpp
index c3654bc80b..9497d87bf3 100644
--- a/Telegram/SourceFiles/chat_helpers/field_autocomplete.cpp
+++ b/Telegram/SourceFiles/chat_helpers/field_autocomplete.cpp
@@ -29,6 +29,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "api/api_chat_participants.h"
 #include "main/main_session.h"
 #include "storage/storage_account.h"
+#include "yukigram/settings/hide_popular_sticker_suggest.h"
 #include "core/application.h"
 #include "core/core_settings.h"
 #include "lang/lang_keys.h"
@@ -429,6 +430,10 @@ FieldAutocomplete::StickerRows FieldAutocomplete::getStickerSuggestions() {
 	const auto list = data->getListByEmoji({ _emoji }, _stickersSeed);
 	auto result = ranges::views::all(
 		list
+	) | ranges::views::filter(
+		[](not_null<DocumentData*> sticker) {
+			return sticker->isStickerSetInstalled() || !Yukigram::Settings::HidePopularStickerSuggest->current();
+		}
 	) | ranges::views::transform([](not_null<DocumentData*> sticker) {
 		return StickerSuggestion{
 			sticker,
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp
new file mode 100644
index 0000000000..645b2e076d
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/hide_popular_sticker_suggest.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HidePopularStickerSuggest = Yukigram::Options::make<bool>(kOptionHidePopularStickerSuggest, {
+	.keywords = { u"yukigram"_q, u"stickers"_q, u"suggested"_q, u"pack"_q, u"popular"_q },
+	.category = "compose",
+});
+
+const char kOptionHidePopularStickerSuggest[] = "hide-popular-sticker-suggest";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.h b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.h
new file mode 100644
index 0000000000..076ceeb385
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_popular_sticker_suggest.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HidePopularStickerSuggest;
+extern const char kOptionHidePopularStickerSuggest[];
+}
