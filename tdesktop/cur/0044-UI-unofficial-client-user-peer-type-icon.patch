From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Wed, 15 Apr 2026 22:19:30 +0300
Subject: [PATCH] [UI] "unofficial client user" peer type icon

---
 Telegram/SourceFiles/history/view/history_view_message.cpp | 2 ++
 Telegram/SourceFiles/ui/chat/chat.style                    | 2 ++
 2 files changed, 4 insertions(+)

diff --git a/Telegram/SourceFiles/history/view/history_view_message.cpp b/Telegram/SourceFiles/history/view/history_view_message.cpp
index c7d8be59f1..5a1592f0a8 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_message.cpp
@@ -146,6 +146,8 @@ std::optional<style::icon> ChatTypeIcon(HistoryItem *item) {
 				return st::msgNameDeletedIcon;
 			} else if (user->isBot() && !user->isSupport() && !user->isRepliesChat()) {
 				return st::msgNameBotIcon;
+			} else if (user->unofficialSecurityRisk()) {
+				return st::msgNameUnofficialIcon;
 			}
 		}
 	}
diff --git a/Telegram/SourceFiles/ui/chat/chat.style b/Telegram/SourceFiles/ui/chat/chat.style
index a8d7910fbb..cf6e0ce8bf 100644
--- a/Telegram/SourceFiles/ui/chat/chat.style
+++ b/Telegram/SourceFiles/ui/chat/chat.style
@@ -770,6 +770,8 @@ msgNameDeletedIcon: icon {{ "dialogs/dialogs_sending", attentionButtonFg, point(
 msgNameDeletedIconSelected: icon {{ "dialogs/dialogs_sending", attentionButtonFgOver, point(4px, 4px) }};
 msgNameForumIcon: icon {{ "dialogs/dialogs_forum", historyPeer4NameFg, point(1px, 4px) }};
 msgNameForumIconSelected: icon {{ "dialogs/dialogs_forum", historyPeer4NameFgSelected, point(1px, 4px) }};
+msgNameUnofficialIcon: icon {{ "dialogs/mini_tag_lock", attentionButtonFg, point(1px, 1px) }};
+msgNameUnofficialIconSelected: icon {{ "dialogs/mini_tag_lock", attentionButtonFgOver, point(1px, 1px) }};
 
 historyGroupCallUserpics: GroupCallUserpics {
 	size: 32px;
-- 
2.53.0

