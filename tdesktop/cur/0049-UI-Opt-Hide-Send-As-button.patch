From: Yuki Sireneva <sylfn@disroot.org>
Date: Tue, 28 Apr 2026 02:36:42 +0300
Subject: [PATCH] [UI][Opt] Hide Send As button

---
 Telegram/CMakeLists.txt                            |  2 ++
 Telegram/SourceFiles/history/history_widget.cpp    | 11 ++++++++++-
 .../SourceFiles/yukigram/settings/hide_send_as.cpp | 14 ++++++++++++++
 .../SourceFiles/yukigram/settings/hide_send_as.h   |  5 +++++
 4 files changed, 31 insertions(+), 1 deletion(-)
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_send_as.cpp
 create mode 100644 Telegram/SourceFiles/yukigram/settings/hide_send_as.h

diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 9e223b80c9..1db4aad271 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1903,6 +1903,8 @@ PRIVATE
     yukigram/settings/force_mobile_layout.h
     yukigram/settings/hide_send_as_premium.cpp
     yukigram/settings/hide_send_as_premium.h
+    yukigram/settings/hide_send_as.cpp
+    yukigram/settings/hide_send_as.h
     yukigram/settings/hide_wall_paper.cpp
     yukigram/settings/hide_wall_paper.h
     yukigram/settings/history_peer_type_icons.cpp
diff --git a/Telegram/SourceFiles/history/history_widget.cpp b/Telegram/SourceFiles/history/history_widget.cpp
index c7044ad8d1..5b40c8a346 100644
--- a/Telegram/SourceFiles/history/history_widget.cpp
+++ b/Telegram/SourceFiles/history/history_widget.cpp
@@ -61,6 +61,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/controls/send_as_button.h"
 #include "ui/controls/silent_toggle.h"
 #include "ui/ui_utility.h"
+#include "yukigram/settings/hide_send_as.h"
 #include "inline_bots/inline_bot_result.h"
 #include "base/event_filter.h"
 #include "base/qt_signal_producer.h"
@@ -3453,6 +3454,14 @@ void HistoryWidget::refreshSuggestPostToggle() {
 }
 
 void HistoryWidget::setupSendAsToggle() {
+	Yukigram::Settings::HideSendAs->changes(
+	) | rpl::on_next([=] {
+		refreshSendAsToggle();
+		updateControlsVisibility();
+		updateControlsGeometry();
+		orderWidgets();
+	}, lifetime());
+
 	session().sendAsPeers().updated(
 	) | rpl::filter([=](Main::SendAsKey key) {
 		return (key.peer == _peer)
@@ -3469,7 +3478,7 @@ void HistoryWidget::refreshSendAsToggle() {
 	Expects(_peer != nullptr);
 
 	const auto key = Main::SendAsKey{ _peer, Main::SendAsType::Message };
-	if (_editMsgId || !session().sendAsPeers().shouldChoose(key)) {
+	if (Yukigram::Settings::HideSendAs->current() || _editMsgId || !session().sendAsPeers().shouldChoose(key)) {
 		_sendAs.destroy();
 		return;
 	} else if (_sendAs) {
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_send_as.cpp b/Telegram/SourceFiles/yukigram/settings/hide_send_as.cpp
new file mode 100644
index 0000000000..753c989745
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_send_as.cpp
@@ -0,0 +1,14 @@
+#include "yukigram/settings/hide_send_as.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *HideSendAs = Yukigram::Options::make(kOptionHideSendAs, {
+    .name = "Hide Send As button",
+    .keywords = { u"yukigram"_q, u"send"_q, u"channels"_q },
+    .category = "compose",
+});
+
+const char kOptionHideSendAs[] = "hide-send-as";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/hide_send_as.h b/Telegram/SourceFiles/yukigram/settings/hide_send_as.h
new file mode 100644
index 0000000000..9113482f57
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/hide_send_as.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *HideSendAs;
+extern const char kOptionHideSendAs[];
+}
