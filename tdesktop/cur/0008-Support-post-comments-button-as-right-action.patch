From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Tue, 21 Apr 2026 20:16:21 +0300
Subject: [PATCH] Support post comments button as right action

---
 Telegram/SourceFiles/core/yukigram_settings.cpp |  8 ++++++++
 Telegram/SourceFiles/core/yukigram_settings.h   |  3 +++
 .../history/view/history_view_message.cpp       | 17 +++++++++++------
 .../settings/sections/settings_yukigram.cpp     |  1 +
 4 files changed, 23 insertions(+), 6 deletions(-)

diff --git a/Telegram/SourceFiles/core/yukigram_settings.cpp b/Telegram/SourceFiles/core/yukigram_settings.cpp
index 7a573035fd..0e10333099 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.cpp
+++ b/Telegram/SourceFiles/core/yukigram_settings.cpp
@@ -9,4 +9,12 @@ base::options::toggle DisableAnimoji({
 	.restartRequired = true,
 });
 
+const char kOptionCommentsButtonAlwaysRight[] = "comments-button-always-right";
+base::options::toggle CommentsButtonAlwaysRight({
+	.id = kOptionCommentsButtonAlwaysRight,
+	.name = "Move comments button to the right",
+	.description = "Takes place of the share button, but results in more compact channel views",
+	.restartRequired = true,
+});
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/core/yukigram_settings.h b/Telegram/SourceFiles/core/yukigram_settings.h
index 112c23c506..398272b296 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.h
+++ b/Telegram/SourceFiles/core/yukigram_settings.h
@@ -7,4 +7,7 @@ namespace Core::YukigramSettings {
 extern const char kOptionDisableAnimoji[];
 extern base::options::toggle DisableAnimoji;
 
+extern const char kOptionCommentsButtonAlwaysRight[];
+extern base::options::toggle CommentsButtonAlwaysRight;
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/history/view/history_view_message.cpp b/Telegram/SourceFiles/history/view/history_view_message.cpp
index 57f8e60f87..07354bed0e 100644
--- a/Telegram/SourceFiles/history/view/history_view_message.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_message.cpp
@@ -13,6 +13,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "base/unixtime.h"
 #include "core/click_handler_types.h" // ClickHandlerContext
 #include "core/ui_integration.h"
+#include "core/yukigram_settings.h"
 #include "history/view/history_view_cursor_state.h"
 #include "history/history_item_components.h"
 #include "history/history_item_helpers.h"
@@ -566,7 +567,7 @@ void Message::animateReaction(Ui::ReactionFlyAnimationArgs &&args) {
 	if (bubble) {
 		// Entry page is always a bubble bottom.
 		auto inner = g;
-		if (_comments) {
+		if (_comments && !displayRightActionComments()) {
 			inner.setHeight(inner.height() - st::historyCommentsButtonHeight);
 		}
 		auto trect = inner.marginsRemoved(st::msgPadding);
@@ -1145,7 +1146,7 @@ void Message::draw(Painter &p, const PaintContext &context) const {
 	const auto customHighlight = mediaDisplayed && media->customHighlight();
 	if (!mediaSelectionIntervals.empty() || customHighlight) {
 		auto localMediaBottom = gForIntervals.top() + gForIntervals.height();
-		if (data()->repliesAreComments() || data()->externalReply()) {
+		if ((data()->repliesAreComments() || data()->externalReply()) && !displayRightActionComments()) {
 			localMediaBottom -= st::historyCommentsButtonHeight;
 		}
 		if (_viewButton) {
@@ -1678,6 +1679,9 @@ void Message::paintCommentsButton(
 	if (!data()->repliesAreComments() && !data()->externalReply()) {
 		return;
 	}
+	if (displayRightActionComments()) {
+		return;
+	}
 	if (!_comments) {
 		_comments = std::make_unique<CommentsButton>();
 		history()->owner().registerHeavyViewPart(const_cast<Message*>(this));
@@ -2378,7 +2382,7 @@ PointState Message::pointState(QPoint point) const {
 			auto mediaOnBottom = (mediaDisplayed && media->isBubbleBottom()) || check || (entry/* && entry->isBubbleBottom()*/);
 			auto mediaOnTop = (mediaDisplayed && media->isBubbleTop()) || (entry && entry->isBubbleTop());
 
-			if (item->repliesAreComments() || item->externalReply()) {
+			if ((item->repliesAreComments() || item->externalReply()) && !displayRightActionComments()) {
 				g.setHeight(g.height() - st::historyCommentsButtonHeight);
 			}
 
@@ -2711,7 +2715,7 @@ BottomRippleMask Message::bottomRippleMask(int buttonHeight) const {
 }
 
 void Message::createCommentsButtonRipple() {
-	auto mask = bottomRippleMask(st::historyCommentsButtonHeight);
+	auto mask = bottomRippleMask(displayRightActionComments() ? 0 : st::historyCommentsButtonHeight);
 	_comments->ripple = std::make_unique<Ui::RippleAnimation>(
 		st::defaultRippleAnimation,
 		std::move(mask.image),
@@ -4512,9 +4516,10 @@ bool Message::displayRightActionComments() const {
 	return !isPinnedContext()
 		&& (context() != Context::SavedSublist)
 		&& data()->repliesAreComments()
+		&& (Core::YukigramSettings::CommentsButtonAlwaysRight.value() || (true
 		&& media()
 		&& media()->isDisplayed()
-		&& !hasBubble();
+		&& !hasBubble()));
 }
 
 std::optional<QSize> Message::rightActionSize() const {
@@ -5313,7 +5318,7 @@ int Message::resizeContentGetHeight(int newWidth) {
 			newHeight += (bottomInfoHeight - st::msgDateFont->height);
 		}
 
-		if (item->repliesAreComments() || item->externalReply()) {
+		if ((item->repliesAreComments() || item->externalReply()) && !displayRightActionComments()) {
 			newHeight += st::historyCommentsButtonHeight;
 		} else if (_comments) {
 			_comments = nullptr;
diff --git a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
index 3bc7adf6fe..081b136e95 100644
--- a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
+++ b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
@@ -77,6 +77,7 @@ void BuildYukigramSectionContent(SectionBuilder &builder) {
     };
 
     addToggle(Core::YukigramSettings::kOptionDisableAnimoji, { u"yukigram"_q, u"disable"_q, u"animoji"_q });
+	addToggle(Core::YukigramSettings::kOptionCommentsButtonAlwaysRight, { u"yukigram"_q, u"comments"_q, u"button"_q, u"right"_q });
 }
 
 class Yukigram : public Section<Yukigram> {
-- 
2.53.0

