From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Thu, 16 Apr 2026 20:50:31 +0300
Subject: [PATCH] (Yukigram) Build support


diff --git a/Telegram/CMakeLists.txt b/Telegram/CMakeLists.txt
index 01291b190c..0465b39914 100644
--- a/Telegram/CMakeLists.txt
+++ b/Telegram/CMakeLists.txt
@@ -1971,6 +1971,9 @@ PRIVATE
     tray.h
 )
 
+file(GLOB_RECURSE yuki_src CONFIGURE_DEPENDS "${src_loc}/yukigram/*.cpp" "${src_loc}/yukigram/*.h")
+target_sources(Telegram PRIVATE ${yuki_src})
+
 if (APPLE)
     nice_target_sources(Telegram ${src_loc}
     PRIVATE
diff --git a/Telegram/build/docker/centos_env/install.sh b/Telegram/build/docker/centos_env/install.sh
new file mode 100755
index 0000000000..d0f38c58ef
--- /dev/null
+++ b/Telegram/build/docker/centos_env/install.sh
@@ -0,0 +1,5 @@
+#!/usr/bin/env bash
+set -exuo pipefail
+
+cd Telegram
+DESTDIR="../$DESTDIR" cmake --install ../out --config "${CONFIG:-Release}" "$@"
diff --git a/build.sh b/build.sh
new file mode 100755
index 0000000000..0a2b177d0e
--- /dev/null
+++ b/build.sh
@@ -0,0 +1,6 @@
+#!/usr/bin/env bash
+set -exuo pipefail
+./run-in-docker.sh \
+    /usr/src/tdesktop/Telegram/build/docker/centos_env/build.sh \
+    -D TDESKTOP_API_ID=611335 \
+    -D TDESKTOP_API_HASH=d524b414d21f4d37f08684c1df41ac9c
diff --git a/install.sh b/install.sh
new file mode 100755
index 0000000000..441c32a088
--- /dev/null
+++ b/install.sh
@@ -0,0 +1,3 @@
+#!/usr/bin/env bash
+set -exuo pipefail
+./run-in-docker.sh env DESTDIR="${DESTDIR:-.}" /usr/src/tdesktop/Telegram/build/docker/centos_env/install.sh "$@"
diff --git a/run-in-docker.sh b/run-in-docker.sh
new file mode 100755
index 0000000000..a3afc6b680
--- /dev/null
+++ b/run-in-docker.sh
@@ -0,0 +1,16 @@
+#!/usr/bin/env bash
+set -exuo pipefail
+TTYFLAGS=
+if tty -s; then
+    TTYFLAGS=-it
+fi
+USERFLAGS=0:0
+if ! docker info -f "{{println .SecurityOptions}}" | grep rootless; then
+    USERFLAGS=$(id -u):$(id -g)
+fi
+docker run --rm $TTYFLAGS \
+    -u $USERFLAGS \
+    -v "$PWD:/usr/src/tdesktop" \
+    -e CONFIG=${CONFIG:-Release} \
+    ghcr.io/telegramdesktop/tdesktop/centos_env@sha256:b582224ed1f9ced75e5a7b3cb4d9f2fd40397e0a476ddec925929d2558348ccc \
+    "$@"

