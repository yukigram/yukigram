diff --git a/Telegram/SourceFiles/yukigram/options.cpp b/Telegram/SourceFiles/yukigram/options.cpp
new file mode 100644
index 0000000000..f89aee8e9e
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/options.cpp
@@ -0,0 +1,67 @@
+#include "yukigram/options.h"
+#include "yukigram/options_database.h"
+#include "yukigram/options_runtime.h"
+
+namespace Yukigram::Options {
+
+std::map<std::string_view, Toggle> &Toggles() {
+	static std::map<std::string_view, Toggle> m;
+	return m;
+}
+
+std::map<std::string_view, std::vector<std::string_view>> &TogglesByCategory() {
+	static std::map<std::string_view, std::vector<std::string_view>> m;
+	return m;
+}
+
+rpl::variable<bool> *make(const char *key, Description &&d, std::function<void(bool)> link, bool defaultValue) {
+	const auto v = std::make_shared<rpl::variable<bool>>(defaultValue);
+
+	const auto base = d.mirrorExperimental ? std::nullopt : std::optional(
+		std::make_shared<
+			base::options::toggle,
+			base::options::descriptor<bool>
+		>({
+			.id = key,
+			.defaultValue = defaultValue,
+			.restartRequired = d.restartRequired,
+		})
+	);
+	rpl::lifetime lifetime;
+
+	const auto key_v = std::string_view(key);
+	TogglesByCategory()[d.category].push_back(key_v);
+	Toggles()[key_v] = {
+		.d = std::move(d),
+		.v = v,
+		._base = base,
+		._lifetime = std::move(lifetime),
+		.link = std::move(link),
+	};
+
+	return v.get();
+}
+
+void update_value(const char *key, bool value) {
+	if (auto it = Toggles().find(std::string_view(key)); it != Toggles().end()) {
+		*it->second.v = value;
+	}
+}
+
+void init() {
+	for (auto &[key, toggle] : Toggles()) {
+		*toggle.v = base::options::lookup<bool>(std::string(key).c_str()).value();
+	}
+}
+
+void link() {
+	for (auto &[key, toggle] : Toggles()) {
+		toggle.v->value() | rpl::on_next([=, link = std::move(toggle.link)](bool value) {
+			base::options::lookup<bool>(std::string(key).c_str()).set(value);
+			link(value);
+		}, toggle._lifetime);
+	}
+}
+
+
+}
diff --git a/Telegram/SourceFiles/yukigram/options.h b/Telegram/SourceFiles/yukigram/options.h
new file mode 100644
index 0000000000..7b270e3260
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/options.h
@@ -0,0 +1,26 @@
+#pragma once
+
+#include "rpl/rpl.h"
+
+#include <QStringList>
+#include <string_view>
+
+namespace Yukigram::Options {
+
+struct Description {
+	std::string_view name;
+	std::string_view description;
+	QStringList keywords = {};
+	std::string_view category;
+	bool restartRequired = false;
+	bool mirrorExperimental = false;
+};
+
+rpl::variable<bool> *make(
+	const char *key,
+	Description &&d,
+	std::function<void(bool)> link = [](bool) {},
+	bool defaultValue = false
+);
+
+}
diff --git a/Telegram/SourceFiles/yukigram/options_database.h b/Telegram/SourceFiles/yukigram/options_database.h
new file mode 100644
index 0000000000..898da57fcb
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/options_database.h
@@ -0,0 +1,25 @@
+#pragma once
+
+#include "yukigram/options.h"
+#include "base/options.h"
+
+#include <map>
+#include <memory>
+#include <optional>
+#include <string_view>
+#include <vector>
+
+namespace Yukigram::Options {
+
+struct Toggle {
+	Description d;
+	std::shared_ptr<rpl::variable<bool>> v;
+	std::optional<std::shared_ptr<base::options::toggle>> _base;
+	rpl::lifetime _lifetime;
+	std::function<void(bool)> link;
+};
+
+std::map<std::string_view, Toggle> &Toggles();
+std::map<std::string_view, std::vector<std::string_view>> &TogglesByCategory();
+
+}
