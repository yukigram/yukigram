diff --git a/Telegram/SourceFiles/yukigram/settings/quick_recent_actions.cpp b/Telegram/SourceFiles/yukigram/settings/quick_recent_actions.cpp
new file mode 100644
index 0000000000..d375b035a0
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/quick_recent_actions.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/quick_recent_actions.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *QuickRecentActions = Yukigram::Options::make<bool>(kOptionQuickRecentActions, {
+	.keywords = { u"yukigram"_q, u"recent"_q, u"actions"_q },
+	.category = "chat",
+});
+
+const char kOptionQuickRecentActions[] = "quick-recent-actions";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/quick_recent_actions.h b/Telegram/SourceFiles/yukigram/settings/quick_recent_actions.h
