@@ -1233,6 +1240,10 @@ void TopBarWidget::updateControlsGeometry() {
 		_infoToggle->moveToRight(_rightTaken, otherButtonsTop);
 		_rightTaken += _infoToggle->width();
 	}
+	_recentActions->moveToRight(_rightTaken, otherButtonsTop);
