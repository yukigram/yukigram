From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <yuki.utk8g@gmail.com>
Date: Tue, 21 Apr 2026 20:35:29 +0300
Subject: [PATCH] Show message id

This patch is adapted from 64Gram.
Original author: c0re100 <corehusky@gmail.com>
---
 Telegram/SourceFiles/core/yukigram_settings.cpp            | 7 +++++++
 Telegram/SourceFiles/core/yukigram_settings.h              | 3 +++
 .../SourceFiles/history/view/history_view_bottom_info.cpp  | 7 ++++++-
 .../SourceFiles/history/view/history_view_bottom_info.h    | 1 +
 Telegram/SourceFiles/history/view/history_view_element.cpp | 3 +++
 .../SourceFiles/settings/sections/settings_yukigram.cpp    | 1 +
 6 files changed, 21 insertions(+), 1 deletion(-)

diff --git a/Telegram/SourceFiles/core/yukigram_settings.cpp b/Telegram/SourceFiles/core/yukigram_settings.cpp
index f980358c0f..72fb52f1e8 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.cpp
+++ b/Telegram/SourceFiles/core/yukigram_settings.cpp
@@ -54,4 +54,11 @@ base::options::toggle TimeWithSeconds({
 	.restartRequired = true,
 });
 
+const char kOptionShowMsgId[] = "show-msgid";
+base::options::toggle ShowMsgId({
+	.id = kOptionShowMsgId,
+	.name = "Show message ID",
+	.restartRequired = true,
+});
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/core/yukigram_settings.h b/Telegram/SourceFiles/core/yukigram_settings.h
index be0bc2babc..e6cdc4d900 100644
--- a/Telegram/SourceFiles/core/yukigram_settings.h
+++ b/Telegram/SourceFiles/core/yukigram_settings.h
@@ -25,4 +25,7 @@ extern base::options::toggle AlwaysShowScheduled;
 extern const char kOptionTimeWithSeconds[];
 extern base::options::toggle TimeWithSeconds;
 
+extern const char kOptionShowMsgId[];
+extern base::options::toggle ShowMsgId;
+
 } // namespace Core::YukigramSettings
diff --git a/Telegram/SourceFiles/history/view/history_view_bottom_info.cpp b/Telegram/SourceFiles/history/view/history_view_bottom_info.cpp
index d9e1b4d257..65a3f363f2 100644
--- a/Telegram/SourceFiles/history/view/history_view_bottom_info.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_bottom_info.cpp
@@ -16,6 +16,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/text/text_utilities.h"
 #include "ui/painter.h"
 #include "core/ui_integration.h"
+#include "core/yukigram_settings.h"
 #include "lang/lang_keys.h"
 #include "history/history_item_components.h"
 #include "history/history_item.h"
@@ -457,7 +458,8 @@ void BottomInfo::layoutDateText() {
 	const auto prefix = !author.isEmpty() ? u", "_q : QString();
 	const auto date = edited + ((_data.flags & Data::Flag::ForwardedDate)
 		? Ui::FormatDateTimeSavedFrom(_data.date)
-		: QLocale().toString(_data.date.time(), Lang::TimeFormat()));
+		: QLocale().toString(_data.date.time(), Lang::TimeFormat()))
+		+ _data.msgId;
 	const auto afterAuthor = prefix + date;
 	const auto afterAuthorWidth = st::msgDateFont->width(afterAuthor);
 	const auto authorWidth = st::msgDateFont->width(author);
@@ -678,6 +680,9 @@ BottomInfo::Data BottomInfoDataFromMessage(not_null<Message*> message) {
 	if (item->isScheduled()) {
 		result.scheduleRepeatPeriod = item->scheduleRepeatPeriod();
 	}
+	if (item->fullId().msg > 0 && Core::YukigramSettings::ShowMsgId.value()) {
+		result.msgId = QString(" (%1)").arg(item->fullId().msg.bare);
+	}
 	if (!forwarded) {
 		return result;
 	}
diff --git a/Telegram/SourceFiles/history/view/history_view_bottom_info.h b/Telegram/SourceFiles/history/view/history_view_bottom_info.h
index ef3d261c86..81e2f918b2 100644
--- a/Telegram/SourceFiles/history/view/history_view_bottom_info.h
+++ b/Telegram/SourceFiles/history/view/history_view_bottom_info.h
@@ -50,6 +50,7 @@ public:
 
 		QDateTime date;
 		QString author;
+		QString msgId;
 		EffectId effectId = 0;
 		int64 tonStake = 0;
 		int stars = 0;
diff --git a/Telegram/SourceFiles/history/view/history_view_element.cpp b/Telegram/SourceFiles/history/view/history_view_element.cpp
index 3f62e02026..5157dafc88 100644
--- a/Telegram/SourceFiles/history/view/history_view_element.cpp
+++ b/Telegram/SourceFiles/history/view/history_view_element.cpp
@@ -699,6 +699,9 @@ QString DateTooltipText(not_null<Element*> view) {
 	if (const auto stars = item->out() ? item->starsPaid() : 0) {
 		dateText += '\n' + tr::lng_you_paid_stars(tr::now, lt_count, stars);
 	}
+	if (const auto msgId = view->data()->fullId().msg) {
+		dateText += '\n' + QString("Message ID: %1").arg(msgId.bare);
+	}
 	return dateText;
 }
 
diff --git a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
index d3c67bd263..1b2c9d5750 100644
--- a/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
+++ b/Telegram/SourceFiles/settings/sections/settings_yukigram.cpp
@@ -83,6 +83,7 @@ void BuildYukigramSectionContent(SectionBuilder &builder) {
     addToggle(Core::YukigramSettings::kOptionWideMessages, { u"yukigram"_q, u"wide"_q, u"messages"_q });
 	addToggle(Core::YukigramSettings::kOptionAlwaysShowScheduled, { u"yukigram"_q, u"show"_q, u"scheduled"_q, u"messages"_q });
 	addToggle(Core::YukigramSettings::kOptionTimeWithSeconds, { u"yukigram"_q, u"time"_q, u"seconds"_q });
+	addToggle(Core::YukigramSettings::kOptionShowMsgId, { u"yukigram"_q, u"message"_q, u"id"_q });
 }
 
 class Yukigram : public Section<Yukigram> {
-- 
