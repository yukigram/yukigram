From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Sun, 17 May 2026 13:15:19 +0300
Subject: [PATCH] (Chat) Go to first message

This patch is adapted from 64Gram.
Original author: c0re100 <corehusky@gmail.com>
---
 Telegram/Resources/langs/yukigram/en.json       |  1 +
 .../SourceFiles/window/window_peer_menu.cpp     | 17 +++++++++++++++++
 2 files changed, 18 insertions(+)

diff --git a/Telegram/Resources/langs/yukigram/en.json b/Telegram/Resources/langs/yukigram/en.json
index 80e3f46568..d4e4b3f51c 100644
--- a/Telegram/Resources/langs/yukigram/en.json
+++ b/Telegram/Resources/langs/yukigram/en.json
@@ -20,6 +20,7 @@
     "info/peer-id/user": "User ID",
     "info/peer-id/unknown": "Peer ID",
     "intro/about": "Welcome to Yukigram, an unofficial patch-based Telegram Desktop fork.",
+    "menu/first-message/title": "First message",
     "nya": "Meow >.<",
     "optgroup/interface": "Interface",
     "optgroup/tweaks": "Tweaks",
diff --git a/Telegram/SourceFiles/window/window_peer_menu.cpp b/Telegram/SourceFiles/window/window_peer_menu.cpp
index 851c629f2f..eebd432b12 100644
--- a/Telegram/SourceFiles/window/window_peer_menu.cpp
+++ b/Telegram/SourceFiles/window/window_peer_menu.cpp
@@ -22,6 +22,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "api/api_chat_participants.h"
 #include "api/api_global_privacy.h"
 #include "lang/lang_keys.h"
+#include "yukigram/lang.h"
 #include "lottie/lottie_icon.h"
 #include "ui/boxes/confirm_box.h"
 #include "base/random.h"
@@ -313,6 +314,7 @@ private:
 	void addToggleNoForwards();
 	void addBlockUser();
 	void addViewDiscussion();
+	void addFirstMessage();
 	void addDirectMessages();
 	void addToggleTopicClosed();
 	void addExportChat();
@@ -917,6 +919,20 @@ void Filler::addViewDiscussion() {
 	}, &st::menuIconDiscussion);
 }
 
+void Filler::addFirstMessage() {
+	const auto peer = _peer->isMegagroup() ? _peer->asMegagroup() : _peer->asChannel();
+	if (!peer) {
+		return;
+	}
+	const auto navigation = _controller;
+	_addAction(ktr("menu/first-message/title"), [=] {
+		navigation->showPeerHistory(
+			peer,
+			Window::SectionShow::Way::Forward,
+			1);
+	}, &st::menuIconShowInChat);
+}
+
 void Filler::addDirectMessages() {
 	const auto channel = _peer->asBroadcast();
 	if (!channel) {
@@ -1762,6 +1778,7 @@ void Filler::fillHistoryActions() {
 	addViewAsTopics();
 	addManageChat();
 	addViewStatistics();
+	addFirstMessage();
 	addStoryArchive();
 	addSupportInfo();
 	addBoostChat();
-- 
