diff --git a/Telegram/SourceFiles/yukigram/settings/quick_admin_list.cpp b/Telegram/SourceFiles/yukigram/settings/quick_admin_list.cpp
new file mode 100644
index 0000000000..7d1ac9ae3c
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/quick_admin_list.cpp
@@ -0,0 +1,13 @@
+#include "yukigram/settings/quick_admin_list.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *QuickAdminList = Yukigram::Options::make(kOptionQuickAdminList, {
+	.keywords = { u"yukigram"_q, u"admin"_q, u"list"_q },
+	.category = "chat",
+});
+
+const char kOptionQuickAdminList[] = "quick-admin-list";
+
+}
