Subject: [PATCH] (Info) Show media DC


diff --git a/Telegram/SourceFiles/media/view/media_view_overlay_widget.cpp b/Telegram/SourceFiles/media/view/media_view_overlay_widget.cpp
index 313b807d42..2026ecde46 100644
--- a/Telegram/SourceFiles/media/view/media_view_overlay_widget.cpp
+++ b/Telegram/SourceFiles/media/view/media_view_overlay_widget.cpp
@@ -1675,6 +1675,17 @@ void OverlayWidget::updateControls() {
 		return dNow;
 	}();
 	_dateText = d.isValid() ? Ui::FormatDateTime(d) : QString();
+	const auto dc = [&]() -> uint32_t {
+		if (_photo) {
+			return _photo->mediaKey().first & 0xFFFF'FFFF;
+		} else if (_document) {
+			return _document->mediaKey().first & 0xFFFF'FFFF;
+		}
+		return -1;
+	}();
+	if (dc != -1) {
+		_dateText += " " + Ui::kQBullet + u" \u2068DC%1"_q.arg(dc);
+	}
 	if (!_fromName.isEmpty()) {
 		_fromNameLabel.setText(
 			st::mediaviewTextStyle,
