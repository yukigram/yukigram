From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Yuki Sireneva <sylfn@disroot.org>
Date: Thu, 4 Jun 2026 01:31:03 +0000
Subject: [PATCH] (Style)(Opt) Sticker size


diff --git a/Telegram/SourceFiles/history/view/media/history_view_sticker.cpp b/Telegram/SourceFiles/history/view/media/history_view_sticker.cpp
index 4ef4cc7be1..67c31f4874 100644
--- a/Telegram/SourceFiles/history/view/media/history_view_sticker.cpp
+++ b/Telegram/SourceFiles/history/view/media/history_view_sticker.cpp
@@ -50,6 +50,7 @@ constexpr auto kMessageEffectMultiplier = 2;
 base::options::option<int> OptionStickerSize({
 	.id = "sticker-size",
 	.name = "Sticker size",
+	.defaultValue = 224,
 });
 
 [[nodiscard]] QImage CacheDiceImage(
diff --git a/Telegram/SourceFiles/ui/chat/chat.style b/Telegram/SourceFiles/ui/chat/chat.style
index e3397a6b64..fcf038ad27 100644
--- a/Telegram/SourceFiles/ui/chat/chat.style
+++ b/Telegram/SourceFiles/ui/chat/chat.style
@@ -213,7 +213,7 @@ mediaInPaletteSelected: TextPalette(defaultTextPalette) {
 
 minPhotoSize: 100px;
 maxMediaSize: 430px;
-maxStickerSize: 224px;
+maxStickerSize: 512px;
 maxAnimatedEmojiSize: 112px;
 maxGifSize: 320px;
 maxVideoMessageSize: 240px;
diff --git a/Telegram/SourceFiles/window/window_media_preview.cpp b/Telegram/SourceFiles/window/window_media_preview.cpp
index 8775e353e8..cecb57568e 100644
--- a/Telegram/SourceFiles/window/window_media_preview.cpp
+++ b/Telegram/SourceFiles/window/window_media_preview.cpp
@@ -364,16 +364,18 @@ QSize MediaPreviewWidget::currentDimensions() const {
 				result = QSize(gif->width(), gif->height());
 			}
 		}
+		const auto maxStickerSize = 224;
 		if (_document->sticker()) {
+		if (Yukigram::Settings::LargeStickerPreview->current()) {
 			box = QSize(st::maxStickerSize, st::maxStickerSize);
-			if (Yukigram::Settings::LargeStickerPreview->current()) {
-				box *= 2;
-			}
+		} else {
+			box = QSize(maxStickerSize, maxStickerSize);
+		}
 			if (_document->isPremiumSticker()) {
 				result = (box /= kPremiumDownscale);
 			}
 		} else {
-			box = QSize(2 * st::maxStickerSize, 2 * st::maxStickerSize);
+			box = QSize(2 * maxStickerSize, 2 * maxStickerSize);
 		}
 	}
 	result = QSize(
diff --git a/Telegram/SourceFiles/yukigram/settings/sticker_size.cpp b/Telegram/SourceFiles/yukigram/settings/sticker_size.cpp
new file mode 100644
index 0000000000..82c6463771
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/sticker_size.cpp
@@ -0,0 +1,17 @@
+#include "yukigram/settings/sticker_size.h"
+#include "yukigram/options.h"
+
+namespace Yukigram::Settings {
+
+rpl::variable<int> *StickerSize = Yukigram::Options::make<int>(kOptionStickerSize, {
+	.keywords = { u"yukigram"_q, u"sticker"_q, u"size"_q },
+	.category = "style",
+	.restartRequired = true,
+	.mirrorExperimental = true,
+	.checkValid = Yukigram::Options::Valid::Bounded(50, 512),
+	.validHint = Yukigram::Options::Valid::BoundedHint(50, 512),
+});
+
+const char kOptionStickerSize[] = "sticker-size";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/sticker_size.h b/Telegram/SourceFiles/yukigram/settings/sticker_size.h
new file mode 100644
index 0000000000..ff1c13369d
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/sticker_size.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<int> *StickerSize;
+extern const char kOptionStickerSize[];
+}
